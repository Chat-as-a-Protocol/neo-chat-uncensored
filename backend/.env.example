# Server
PORT=3001
NODE_ENV=development

# Venice AI
VENICE_API_KEY=...
VENICE_MODEL=<venice-model-id>
# Optional: override Venice API base URL.
# VENICE_API_BASE=https://api.venice.ai/api/v1

# JWT Auth
JWT_SECRET=super_secret_key_min_32_chars

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://...

# Public URLs
FRONTEND_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:3001

# FlowPay
# Em producao, manter https://api.flowpay.cash.
# Nunca usar https://api.noxai.chat aqui.
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=fp_...
FLOWPAY_WEBHOOK_SECRET=...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=NØX <send@noxai.chat>
MAGIC_LINK_EXPIRATION_MINUTES=10

# Feature Toggles
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
ENABLE_PRO_ENGINE_CHECKOUT=false
ENABLE_FLOWPAY_DIAGNOSTICS=false
