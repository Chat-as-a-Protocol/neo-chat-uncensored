# Server
PORT=3001
NODE_ENV=development

# Venice AI
VENICE_API_KEY=sua_chave_aqui
VENICE_MODEL=venice-uncensored-role-play

# JWT Auth
JWT_SECRET=super_secret_key_min_32_chars

# Infrastructure
# DICA: Na Railway, use as URLs INTERNAS (Private) para Redis e DB para maior velocidade/segurança.
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://...
# IMPORTANTE: Use a URL PÚBLICA do seu frontend (ex: https://meu-app.up.railway.app)
FRONTEND_URL=http://localhost:4321

# FlowPay Integration
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=fp_...
FLOWPAY_WEBHOOK_SECRET=whsec_...

# Feature Toggles
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
