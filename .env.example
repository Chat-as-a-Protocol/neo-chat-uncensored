# =========================================================
# NØX · ENV TEMPLATE (SAFE)
# ---------------------------------------------------------
# Este arquivo é apenas um template.
# NUNCA coloque valores reais aqui.
# Segredos reais devem existir apenas:
# - no Railway (produção)
# - no .env local (não versionado)
# =========================================================

# ========================
# AI PROVIDER
# ========================
VENICE_API_KEY=REPLACE_ME
VENICE_MODEL=REPLACE_ME
VENICE_API_BASE=https://api.venice.ai/api/v1

# ========================
# AUTH / SECURITY
# ========================
JWT_SECRET=REPLACE_ME_MIN_64_CHARS_SECURE

# ========================
# PAYMENTS / FLOW
# ========================
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=REPLACE_ME
FLOWPAY_WEBHOOK_SECRET=REPLACE_ME
# Nexus is an upstream webhook fan-out caller.
# NØX does not call Nexus in the current payment flow.
# The shared contract is the webhook signature secret above.

# ========================
# INFRASTRUCTURE
# ========================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
REDIS_URL=redis://USER:PASSWORD@HOST:PORT
PORT=3001

# ========================
# PUBLIC / FRONTEND
# ========================
# Lista separada por vírgula
FRONTEND_URL=https://noxai.chat
PUBLIC_API_URL=https://api.noxai.chat

# ========================
# FEATURE FLAGS
# ========================
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
ENABLE_PRO_ENGINE_CHECKOUT=false
ENABLE_FLOWPAY_DIAGNOSTICS=false
PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS=false
CODE_LOCK=false

# ========================
# ECONOMY / LEDGER
# ========================
ALLOW_NEGATIVE_BALANCE=false

# ========================
# EMAIL / MAGIC LINK
# ========================
MAGIC_LINK_EXPIRATION_MINUTES=10
RESEND_API_KEY=REPLACE_ME
RESEND_FROM_EMAIL="NØX <send@noxai.chat>"
RESEND_API_URL=https://api.resend.com/emails

# ========================
# OPTIONAL / DEBUG
# ========================
NODE_ENV=development
LOG_LEVEL=info
HOST=0.0.0.0
