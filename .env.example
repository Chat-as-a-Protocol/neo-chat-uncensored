# Venice AI
VENICE_API_KEY=....
VENICE_MODEL=llama-3.3-70b

# JWT
JWT_SECRET=....

# FlowPay (Ecossistema NEO)
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=fp_...
NEO_CHAT_WEBHOOK_SECRET=nexus_...

# Infrastructure (Railway cria automaticamente)
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# Config
# IMPORTANTE: Use a URL PÚBLICA do seu backend aqui (ex: https://api.up.railway.app)
# O browser do usuário não alcança URLs internas da Railway.
FRONTEND_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:3001

# Feature Toggles
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
