# =========================================================
# NØX · FRONTEND/SSR ENV TEMPLATE (SAFE)
# ---------------------------------------------------------
# Este arquivo é apenas um template.
# NUNCA coloque valores reais aqui.
# Valores reais devem existir apenas:
# - no Railway (produção)
# - no .env local (não versionado)
# Este template é consumido pelo frontend Astro/SSR.
# Segredos de backend ficam em backend/.env e backend/.env.example.
# =========================================================

# ========================
# SSR INFRASTRUCTURE
# ========================
PORT=3000
HOST=0.0.0.0
# URL interna do backend (rede privada Railway). Usado SOMENTE server-side
# pelo deep health check (/health/deep). Nunca exposto ao browser.
BACKEND_URL=http://backend.railway.internal:3001

# ========================
# PUBLIC / FRONTEND
# ========================
# Lista separada por vírgula
FRONTEND_URL=https://noxai.chat
PUBLIC_API_URL=https://api.noxai.chat

# ========================
# FEATURE FLAGS
# ========================
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS=false

# ========================
# OPTIONAL / DEBUG
# ========================
NODE_ENV=development
