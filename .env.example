# Venice AI
VENICE_API_KEY=....
VENICE_MODEL=uncensured

# JWT
JWT_SECRET=....

# FlowPay (Ecossistema NEO)
# FLOWPAY_API_URL é o endpoint do FlowPay, não a API pública deste app.
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=fp_...
NEO_CHAT_WEBHOOK_SECRET=nexus_...

# Infrastructure (Railway cria automaticamente)
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# Config
# IMPORTANTE: Use a URL PÚBLICA do seu backend aqui (ex: https://api.noxai.chat)
# O browser do usuário não alcança URLs internas da Railway.
FRONTEND_URL=https://noxai.chat
PUBLIC_API_URL=https://api.noxai.chat

# Feature Toggles
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true

# Resend (Email Service)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=NØX <send@noxai.chat>
