# Venice AI
VENICE_API_KEY=...
VENICE_MODEL=<venice-model-id>

# JWT
JWT_SECRET=...

# FlowPay
# FLOWPAY_API_URL e o endpoint do FlowPay, nao a API publica deste app.
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=fp_...
FLOWPAY_WEBHOOK_SECRET=...

# Infrastructure
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# Public URLs
# FRONTEND_URL: Dominios permitidos pelo CORS (suporta lista separada por virgula).
FRONTEND_URL=https://noxai.chat,https://www.noxai.chat,https://inspiring-vitality-production.up.railway.app
PUBLIC_API_URL=https://api.noxai.chat

# Feature Toggles
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
ENABLE_PRO_ENGINE_CHECKOUT=false
ENABLE_FLOWPAY_DIAGNOSTICS=false
PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS=false

# Auth Email
MAGIC_LINK_EXPIRATION_MINUTES=10
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=NØX <send@noxai.chat>
