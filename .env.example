# Venice AI
VENICE_API_KEY=...
VENICE_MODEL=venice-uncensored-1-2
# Optional: override Venice API base URL (default: https://api.venice.ai/api/v1)
# VENICE_API_BASE=https://api.venice.ai/api/v1

# JWT
JWT_SECRET=...

# FlowPay
# FLOWPAY_API_URL e o endpoint do FlowPay, nao a API publica deste app.
FLOWPAY_API_URL=https://api.flowpay.cash
FLOWPAY_API_KEY=fp_...
FLOWPAY_WEBHOOK_SECRET=...

# Infrastructure
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# Public URLs
# O browser do usuario chama PUBLIC_API_URL.
# O backend usa FRONTEND_URL para CORS, magic link e callbacks.
FRONTEND_URL=https://noxai.chat
PUBLIC_API_URL=https://api.noxai.chat

# Feature Toggles
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
ENABLE_PRO_ENGINE_CHECKOUT=false
ENABLE_FLOWPAY_DIAGNOSTICS=false
PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS=false

# Auth Email
MAGIC_LINK_EXPIRATION_MINUTES=10
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=NØX <send@noxai.chat>
