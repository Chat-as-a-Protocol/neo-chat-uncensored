# =========================================================
# NØX · WORKSPACE ENV TEMPLATE INDEX (SAFE)
# ---------------------------------------------------------
# Este repositório utiliza arquitetura modular com pnpm.
# Os templates específicos por módulo vivem em:
# - Frontend: frontend/.env.example
# - Backend:  backend/.env.example
# 
# Contrato de engenharia: docs/ENV_CONTRACT.md
# NUNCA inclua segredos reais neste arquivo.
# =========================================================

# ========================
# FRONTEND / ASTRO SSR (frontend/.env.example)
# ========================
PORT=8080
HOST=0.0.0.0
FRONTEND_URL=https://noxai.chat
PUBLIC_API_URL=https://api.noxai.chat
BACKEND_URL=http://backend.railway.internal:3001

# ========================
# BACKEND API (backend/.env.example)
# ========================
