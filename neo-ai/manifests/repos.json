          "./Dockerfile"
        ]
      },
      "publicSurface": {
        "domains": [
          "api-chat.neoprotocol.space"
        ],
        "apiEndpoints": [
          "/api/v1/chat",
          "/api/v1/auth"
        ],
        "webhookEndpoints": [
          "/api/v1/stripe-webhook"
        ]
      },
      "dependencies": {
        "internal": [],
        "external": [
          "Stripe",
          "Redis Cloud",
          "PostgreSQL"
        ]
      },
      "evidence": [
        "./backend/package.json"
      ]
