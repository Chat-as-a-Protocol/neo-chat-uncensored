        "./astro.config.mjs"
      ]
    },
    {
      "name": "chat-api-backend",
      "localPath": "./backend",
      "remote": "https://github.com/neomello/chat-api-backend.git",
      "role": "Core API & Subscription Engine",
      "runtime": {
        "category": "server-runtime",
        "framework": "Express",
        "node": ">=20.x"
      },
      "localDevelopment": {
        "primaryCommand": "pnpm start",
        "ports": [
          {
            "purpose": "Express API",
            "value": 3001,
            "source": "server.js"
          }
        ],
        "notes": [
          "Requires Redis and PostgreSQL."
        ]
      },
      "deployment": {
        "primaryPlatform": "Railway",
