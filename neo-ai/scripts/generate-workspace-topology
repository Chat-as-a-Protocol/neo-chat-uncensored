#!/usr/bin/env python3

from __future__ import annotations

import json
from datetime import datetime
from pathlib import Path
import sys


def main() -> int:
    root = Path(__file__).resolve().parents[1]
    repos = json.loads((root / "manifests" / "repos.json").read_text()).get("repositories", [])
    integrations = json.loads((root / "manifests" / "integrations.json").read_text()).get("integrations", [])

    now = datetime.now().astimezone().isoformat(timespec="seconds")
    lines: list[str] = []

    lines.append("# Workspace Topology")
    lines.append("")
    lines.append(f"Generated at: `{now}`")
    lines.append("")

    lines.append("## Repositories")
    lines.append("")
    lines.append("name | role | devCommand | remote")
    lines.append("--- | --- | --- | ---")
    for r in repos:
        name = r.get("name", "")
        role = r.get("role", "")
        dev = (r.get("localDevelopment", {}) or {}).get("primaryCommand", "")
        remote = r.get("remote", "")
        lines.append(f"{name} | {role} | {dev} | {remote}")

    lines.append("")
    lines.append("## Integrations")
    lines.append("")
    lines.append("id | status | producer -> consumer | type")
    lines.append("--- | --- | --- | ---")
    for i in integrations:
        iid = i.get("id", "")
        status = i.get("status", "")
        itype = i.get("type", "")
        prod = (i.get("producer", {}) or {}).get("repo", "")
        cons = (i.get("consumer", {}) or {}).get("repo", "")
        lines.append(f"{iid} | {status} | {prod} -> {cons} | {itype}")

    sys_stdout = "\n".join(lines).rstrip() + "\n"
    print(sys_stdout, end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
