---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('legal', 'terms-and-conditions');
if (!entry) {
  return Astro.redirect('/');
}
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | NØX`}>
  <main class="legal-shell">
    <img src="/nox_vert.webp" alt="" aria-hidden="true" class="legal-bg-logo" />
    <article class="legal-card">
      <h1>{entry.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
      <a href="/">Voltar</a>
    </article>
  </main>
</Layout>

<style>
  .legal-shell {
    position: relative;
    overflow: hidden;
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 24px;
    background: radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.08), transparent 48%), #11131a;
  }

  /* Logo gigante ancorada no topo, estourando as laterais, por trás do card
     para o glassmorphism do .legal-card borrá-la. */
  .legal-bg-logo {
    position: absolute;
    top: -6vh;
    left: 50%;
    transform: translateX(-50%);
    width: 150vw;
    max-width: none;
    height: auto;
    opacity: 0.32;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .legal-card {
    position: relative;
    z-index: 1;
    width: min(720px, 100%);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    padding: 24px;
    color: rgba(245, 245, 248, 0.95);
    display: grid;
    gap: 14px;
  }

  h1 {
    font-size: clamp(28px, 4vw, 42px);
    margin-bottom: 8px;
  }

  .prose :global(p) {
    margin: 0 0 16px 0;
    line-height: 1.6;
    color: rgba(245, 245, 248, 0.82);
  }

  .prose :global(ol) {
    color: rgba(245, 245, 248, 0.82);
    padding-left: 20px;
  }

  .prose :global(li) {
    margin-bottom: 8px;
  }

  .prose :global(strong) {
    color: #fff;
    font-weight: 600;
  }

  a {
    margin-top: 8px;
    width: fit-content;
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.08);
  }
</style>
