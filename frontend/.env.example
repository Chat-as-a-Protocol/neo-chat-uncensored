# =========================================================
# NØX · FRONTEND / ASTRO SSR ENV TEMPLATE (SAFE)
# ---------------------------------------------------------
# Este arquivo é apenas um template seguro de variáveis.
# NUNCA inclua segredos reais aqui.
# Contrato de engenharia: ../docs/ENV_CONTRACT.md
# =========================================================

# ========================
# SSR INFRASTRUCTURE
# ========================
PORT=8080
HOST=0.0.0.0

# URL interna do backend (rede privada Railway).
# Lido EXCLUSIVAMENTE pelo servidor SSR em /health/deep. Nunca exposto ao browser.
BACKEND_URL=http://backend.railway.internal:3001

# ========================
# PUBLIC / FRONTEND
# ========================
FRONTEND_URL=https://noxai.chat
PUBLIC_API_URL=https://api.noxai.chat

# ========================
# FEATURE FLAGS
# ========================
ENABLE_AUTH_PAGES=true
ENABLE_LANDING_PAGE=true
PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS=false

# ========================
# OPTIONAL / DEBUG
# ========================
NODE_ENV=development
