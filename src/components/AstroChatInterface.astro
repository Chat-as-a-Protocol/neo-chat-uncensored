<div class="chat-ui-shell">
  <header class="chat-header" aria-label="brand">
    <div class="brand-pill">
      <img src="/nox_vert.webp" alt="NØX" class="brand-logo" />
      
      <div id="persona-container" class="persona-selector" style="display: none;">
        <select id="persona-select" aria-label="Selecionar Persona">
          <option value="nox">NØX Core</option>
        </select>
      </div>

      <div class="header-actions">
        <div id="quota-indicator" class="quota-badge" title="Mensagens hoje">
          <span class="quota-count">--/--</span>
        </div>
        <div class="upgrade-prompt" id="upgrade-prompt" style="display: none;">
          <button onclick="window.location='/upgrade'">PRO</button>
        </div>
        <button id="clear-history-btn" class="icon-btn" title="Limpar conversa" aria-label="Limpar conversa">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
        </button>
        <button id="menu-toggle" class="menu-toggle" aria-label="Abrir menu" aria-expanded="false" aria-controls="nav-menu">
          <span></span><span></span><span></span>
        </button>
      </div>

      <nav id="nav-menu" class="nav-menu" aria-label="Navegação">
        <a href="/upgrade" class="nav-item nav-item--cta">
          <span>Assinar PRO</span>
          <small>Libere tudo, sem limites</small>
        </a>
        <a href="/pricing" class="nav-item">Preços</a>
        <a href="/account" class="nav-item">Minha conta</a>
        <a href="https://t.me/nox_ia" target="_blank" rel="noopener noreferrer" class="nav-item">Telegram</a>
        <div class="nav-divider"></div>
        <div class="nav-legal">
          <a href="/privacy">Privacy</a>
          <span>·</span>
          <a href="/terms">Terms</a>
        </div>
      </nav>

      <div class="noise-overlay"></div>
    </div>
  </header>

  <div id="clear-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
        <h3>Resetar conversa?</h3>
      </div>
      <p>Esta ação limpará permanentemente todo o histórico desta sessão. NØX não terá memória do que falaram anteriormente.</p>
      <div class="modal-actions">
        <button id="cancel-clear" class="modal-btn-cancel">Cancelar</button>
        <button id="confirm-clear" class="modal-btn-confirm">Confirmar Reset</button>
      </div>
      <div class="noise-overlay"></div>
    </div>
  </div>

  <div
    id="messages-container"
    class="messages-container"
    role="log"
    aria-live="polite"
    aria-relevant="additions text"
    tabindex="0"
  ></div>

  <form id="chat-form" class="chat-form" autocomplete="off">
    <label class="sr-only" for="chat-input">Mensagem</label>
    <div class="input-wrapper">
      <textarea id="chat-input" placeholder="Digite aqui..." rows="1"></textarea>
      <button type="submit" id="send-button" disabled aria-label="Enviar mensagem">
        <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </div>
    <div class="noise-overlay"></div>
  </form>

  <div id="marketing-barrier" class="marketing-barrier" style="display: none;">
    <div class="marketing-content">
      <div class="lamp-icon">◬</div>
      <h3>E aí, tá curtindo?...</h3>
      <p>Dá uma moral e cria uma conta, é grátis.</p>
      
      <div class="marketing-actions">
        <button onclick="window.location='/signup'" class="btn-signup-marketing">CRIAR CONTA GRÁTIS</button>
        <button onclick="window.location='/login'" class="btn-login-marketing">JÁ TENHO CONTA</button>
      </div>
      
      <div class="noise-overlay"></div>
    </div>
  </div>
</div>

<script>
  const formEl = document.getElementById('chat-form');
  const inputEl = document.getElementById('chat-input');
  const sendBtnEl = document.getElementById('send-button');
  const messagesContainerEl = document.getElementById('messages-container');
  const clearBtnEl = document.getElementById('clear-history-btn');
  const clearModalEl = document.getElementById('clear-modal');
  const confirmClearBtn = document.getElementById('confirm-clear');
  const cancelClearBtn = document.getElementById('cancel-clear');
  const marketingBarrierEl = document.getElementById('marketing-barrier');

  if (
    !(formEl instanceof HTMLFormElement) ||
    !(inputEl instanceof HTMLTextAreaElement) ||
    !(sendBtnEl instanceof HTMLButtonElement) ||
    !(messagesContainerEl instanceof HTMLDivElement) ||
    !(clearBtnEl instanceof HTMLButtonElement) ||
    !(clearModalEl instanceof HTMLDivElement) ||
    !(confirmClearBtn instanceof HTMLButtonElement) ||
    !(cancelClearBtn instanceof HTMLButtonElement)
  ) {
    throw new Error('Chat interface não inicializada corretamente');
  }

  const form = formEl;
  const input = inputEl;
  const sendBtn = sendBtnEl;
  const messagesContainer = messagesContainerEl;
  const clearBtn = clearBtnEl;
  const clearModal = clearModalEl;
  const confirmClear = confirmClearBtn;
  const cancelClear = cancelClearBtn;

  const productionApiUrl = 'https://api.noxai.chat';
  const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
  const configuredApiUrl = String(import.meta.env.PUBLIC_API_URL || '').trim().replace(/\/$/, '');
  const configuredApiIsLocal = /^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i.test(configuredApiUrl);
  const apiUrl = configuredApiUrl && (isLocalhost || !configuredApiIsLocal)
    ? configuredApiUrl
    : (isLocalhost ? 'http://localhost:3001' : productionApiUrl);
  const autoscrollThreshold = 56;
  const tokenStorageKey = 'nox_token';
  const tokenCookieMaxAge = 7 * 24 * 60 * 60;

  interface MessageOptions {
    streaming?: boolean;
    fromInput?: boolean;
    createdAt?: Date;
    id?: string;
    forceScroll?: boolean;
  }

  interface ChatOptions {
    isRetry?: boolean;
  }

  interface ApiErrorPayload {
    error?: string;
    message?: string;
    usage?: number;
    limit?: number;
    upgradeUrl?: string;
  }

  interface UsagePayload {
    today?: number;
    limit?: number;
    tier?: string;
    plan?: string;
    remaining?: number;
    balance?: number;
    name?: string;
  }

  class ChatApiError extends Error {
    status: number;
    payload: ApiErrorPayload | null;
    rawBody: string;

    constructor(status: number, payload: ApiErrorPayload | null, rawBody: string) {
      super(payload?.error || `API Error ${status}`);
      this.name = 'ChatApiError';
      this.status = status;
      this.payload = payload;
      this.rawBody = rawBody;
    }
  }

  const openingAssistantMessage = "NØX na ativa.";
  let messages: { role: string; content: string }[] = [];
  let guestSessionPromise: Promise<string | null> | null = null;
  let isGuestAccess = true;
  let quotaSynced = false;
  let quotaLocked = false;
  let latestUsage: UsagePayload | null = null;
  let marketingRedirectTimeout: number | null = null;

  // 1. Persistência: Tentar carregar do localStorage
  try {
    const saved = localStorage.getItem('neo_chat_history');
    if (saved) {
      messages = JSON.parse(saved);
      // Re-renderizar histórico salvo
      messages.forEach(msg => {
        appendMessage(msg.role, msg.content, { forceScroll: false });
      });
    } else {
      messages = [{ role: 'assistant', content: openingAssistantMessage }];
      appendMessage('assistant', openingAssistantMessage, { forceScroll: true, createdAt: new Date() });
    }
  } catch (error) {
    messages = [{ role: 'assistant', content: openingAssistantMessage }];
    appendMessage('assistant', openingAssistantMessage, { forceScroll: true, createdAt: new Date() });
  }

  function saveHistory() {
    try {
      // Persistência Resiliente: Truncar antes de salvar
      const MAX_HISTORY = 30; // Manter apenas as últimas 30 mensagens
      if (messages.length > MAX_HISTORY) {
        messages = messages.slice(-MAX_HISTORY);
      }
      localStorage.setItem('neo_chat_history', JSON.stringify(messages));
    } catch (e) {
      console.warn('[History] Falha ao salvar no localStorage:', e);
    }
  }

  function clearHistory() {
    localStorage.removeItem('neo_chat_history');
    messages = [{ role: 'assistant', content: openingAssistantMessage }];
    messagesContainer.innerHTML = '';
    appendMessage('assistant', openingAssistantMessage, { forceScroll: true, createdAt: new Date() });
  }

  function openClearModal() {
    clearModal.style.display = 'flex';
    cancelClear.focus(); // A11y: Foco inicial no cancelar (segurança)
  }

  function closeClearModal() {
    clearModal.style.display = 'none';
    clearBtn.focus(); // A11y: Retornar foco ao botão que abriu
  }

  clearBtn.addEventListener('click', openClearModal);
  cancelClear.addEventListener('click', closeClearModal);

  confirmClear.addEventListener('click', () => {
    clearHistory();
    closeClearModal();
  });

  // A11y: Fechar com Escape
  window.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      if (clearModal.style.display === 'flex') closeClearModal();
    }
  });

  // Fechar modal ao clicar fora
  clearModal.addEventListener('click', (e: MouseEvent) => {
    if (e.target === clearModal) {
      clearModal.style.display = 'none';
    }
  });

  function getOrCreateGuestId() {
    let guestId = localStorage.getItem('neo_guest_id');
    if (!guestId) {
      guestId = crypto.randomUUID ? crypto.randomUUID() : `guest_${Date.now()}_${Math.random().toString(16).slice(2)}`;
      localStorage.setItem('neo_guest_id', guestId);
    }
    return guestId;
  }

  function getCookie(name: string) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop()?.split(';').shift();
  }

  function persistAuthToken(token: string) {
    const secure = window.location.protocol === 'https:' ? '; Secure' : '';
    // Priorizamos Cookies para suporte a SSR, mas mantemos localStorage como fallback legado
    localStorage.setItem(tokenStorageKey, token);
    document.cookie = `${tokenStorageKey}=${token}; path=/; max-age=${tokenCookieMaxAge}; SameSite=Lax${secure}`;
  }

  function clearAuthToken() {
    const secure = window.location.protocol === 'https:' ? '; Secure' : '';
    localStorage.removeItem(tokenStorageKey);
    document.cookie = `${tokenStorageKey}=; path=/; max-age=0; SameSite=Lax${secure}`;
  }

  function decodeSessionToken(token: string): { id?: string; guest?: boolean; tier?: string } | null {
    try {
      const payload = token.split('.')[1];
      if (!payload) return null;
      const normalized = payload.replace(/-/g, '+').replace(/_/g, '/');
      const padded = normalized.padEnd(Math.ceil(normalized.length / 4) * 4, '=');
      return JSON.parse(atob(padded));
    } catch {
      return null;
    }
  }

  function isGuestToken(token: string) {
    const session = decodeSessionToken(token);
    return Boolean(
      session?.guest ||
      String(session?.id || '').startsWith('guest_') ||
      session?.tier === 'guest'
    );
  }

  function selectStoredToken(cookieToken: string | undefined, storedToken: string | null) {
    if (cookieToken && storedToken && isGuestToken(cookieToken) && !isGuestToken(storedToken)) {
      persistAuthToken(storedToken);
      return storedToken;
    }

    return cookieToken || storedToken;
  }

  function getStoredToken() {
    return selectStoredToken(getCookie(tokenStorageKey), localStorage.getItem(tokenStorageKey));
  }

  async function ensureSession() {
    const existingToken = getStoredToken();
    if (existingToken) return existingToken;

    if (!guestSessionPromise) {
      guestSessionPromise = (async () => {
        const response = await fetch(`${apiUrl}/api/auth/guest`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ deviceId: getOrCreateGuestId() }),
        });

        if (!response.ok) {
          throw new Error('Guest session unavailable');
        }

        const result = await response.json();
        if (!result.token) {
          throw new Error('Guest session token missing');
        }

        persistAuthToken(result.token);
        return result.token;
      })().finally(() => {
        guestSessionPromise = null;
      });
    }

    return guestSessionPromise;
  }

  function isGuestSession() {
    if (quotaSynced) return isGuestAccess;
    const token = getStoredToken();
    if (!token) return true;
    return isGuestToken(token);
  }

  function isMobileComposerMode() {
    return window.matchMedia('(pointer: coarse)').matches || window.innerWidth <= 820;
  }

  function syncSendAvailability() {
    sendBtn.disabled = quotaLocked || isSending || input.value.trim() === '';
  }

  function setComposerLocked(locked: boolean) {
    quotaLocked = locked;
    form.classList.toggle('is-locked', locked);
    input.disabled = locked;
    syncSendAvailability();
  }

  function isUsageExhausted(data: UsagePayload) {
    const today = Number(data.today);
    const limit = Number(data.limit);
    const remaining = Number.isFinite(Number(data.remaining))
      ? Number(data.remaining)
      : limit - today;

    return Number.isFinite(today) && Number.isFinite(limit) && limit > 0 && remaining <= 0;
  }

  let streamingBubble: HTMLElement | null = null;
  let typingIndicatorEl: HTMLElement | null = null;
  let isSending = false;
  let firingTimeout: any = null;

  function formatTime(date = new Date()) {
    return date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  }

  function isUserNearBottom() {
    const distance = messagesContainer.scrollHeight - messagesContainer.scrollTop - messagesContainer.clientHeight;
    return distance <= autoscrollThreshold;
  }

  function scrollToBottom(smooth = true) {
    messagesContainer.scrollTo({
      top: messagesContainer.scrollHeight,
      behavior: smooth ? 'smooth' : 'auto',
    });
  }

  function maybeScrollToBottom(force = false) {
    if (force || isUserNearBottom()) {
      scrollToBottom(true);
    }
  }

  function escapeHtml(text: string) {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatContent(text: string) {
    let formatted = escapeHtml(text);

    // 1. Raciocínio / Pensamento (Collapsible)
    formatted = formatted.replace(/&lt;thought&gt;([\s\S]*?)&lt;\/thought&gt;/g, (_match: string, content: string) => {
      return `
        <details class="thought-accordion" open>
          <summary>Raciocínio Interno</summary>
          <div class="thought-content">${content}</div>
        </details>
      `;
    });

    // 2. Code Blocks
    formatted = formatted.replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>');

    // 3. Bold
    formatted = formatted.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

    // 4. Quebras de linha
    return formatted.replace(/\n/g, '<br/>');
  }

  function createMeta(_role: string, createdAt: Date) {
    const meta = document.createElement('div');
    meta.className = 'message-meta-inline';

    const time = document.createElement('time');
    time.className = 'message-time';
    time.dateTime = createdAt.toISOString();
    time.textContent = formatTime(createdAt);

    meta.appendChild(time);
    return meta;
  }

  const COPY_ICON = '<svg class="ic ic-copy" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
  const CHECK_ICON = '<svg class="ic ic-check" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';

  async function copyText(text: string): Promise<boolean> {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      try {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        const ok = document.execCommand('copy');
        ta.remove();
        return ok;
      } catch {
        return false;
      }
    }
  }

  function createCopyButton(contentEl: HTMLElement) {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'copy-btn';
    btn.title = 'Copiar';
    btn.setAttribute('aria-label', 'Copiar mensagem');
    btn.innerHTML = `${COPY_ICON}${CHECK_ICON}<span class="copy-label">Copiar</span>`;

    let resetTimer = 0;
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const text = (contentEl.innerText || contentEl.textContent || '').trim();
      if (!text) return;
      const ok = await copyText(text);
      if (!ok) return;
      const label = btn.querySelector('.copy-label');
      btn.classList.add('is-copied');
      btn.setAttribute('aria-label', 'Copiado');
      if (label) label.textContent = 'Copiado';
      window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        btn.classList.remove('is-copied');
        btn.setAttribute('aria-label', 'Copiar mensagem');
        if (label) label.textContent = 'Copiar';
      }, 1600);
    });
    return btn;
  }

  function buildMessageNode(role: string, content: string, opts: MessageOptions = {}) {
    const wrapper = document.createElement('div');
    wrapper.className = `message-row ${role === 'user' ? 'is-user' : 'is-assistant'}`;
    wrapper.dataset.role = role;

    const bubble = document.createElement('div');
    bubble.className = `message-bubble ${role === 'user' ? 'user-bubble' : 'assistant-bubble'}`;
    if (opts.streaming) bubble.classList.add('is-streaming');
    if (opts.fromInput) bubble.classList.add('from-input');

    const contentEl = document.createElement('div');
    contentEl.className = 'message-content';
    contentEl.innerHTML = formatContent(content);

    bubble.appendChild(contentEl);

    const meta = createMeta(role, opts.createdAt || new Date());
    if (role !== 'user') {
      meta.classList.add('has-copy');
      meta.appendChild(createCopyButton(contentEl));
    }
    bubble.appendChild(meta);
    wrapper.appendChild(bubble);

    return { wrapper, bubble, contentEl };
  }

  function appendMessage(role: string, content: string, opts: MessageOptions = {}) {
    const shouldForceScroll = opts.forceScroll === true;
    isUserNearBottom();
    
    const { wrapper, bubble, contentEl } = buildMessageNode(role, content, opts);
    if (opts.id) wrapper.id = opts.id;

    messagesContainer.appendChild(wrapper);
    requestAnimationFrame(() => bubble.classList.add('is-visible'));
    maybeScrollToBottom(shouldForceScroll);
    return { wrapper, bubble, contentEl };
  }

  function updateMessage(id: string, newContent: string): void {
    const shouldStayAtBottom = isUserNearBottom();
    const wrapper = document.getElementById(id);
    if (!wrapper) return;

    const contentEl = wrapper.querySelector('.message-content');
    if (contentEl) {
      contentEl.innerHTML = formatContent(newContent);
    }

    if (shouldStayAtBottom) {
      maybeScrollToBottom(true);
    }
  }

  function showTypingIndicator(): void {
    if (typingIndicatorEl) return;

    const wasNearBottom = isUserNearBottom();

    const wrapper = document.createElement('div');
    wrapper.className = 'message-row is-assistant typing-row';
    wrapper.dataset.role = 'assistant';

    const bubble = document.createElement('div');
    bubble.className = 'message-bubble assistant-bubble typing-bubble is-visible';

    const thinking = document.createElement('div');
    thinking.className = 'thinking-indicator';
    thinking.innerHTML = '<span>pensando</span><span class="thinking-dots"><span>.</span><span>.</span><span>.</span></span>';

    bubble.appendChild(thinking);
    wrapper.appendChild(bubble);

    messagesContainer.appendChild(wrapper);
    typingIndicatorEl = wrapper;

    if (wasNearBottom) {
      maybeScrollToBottom(true);
    }
  }

  function hideTypingIndicator(): void {
    if (!typingIndicatorEl) return;
    typingIndicatorEl.remove();
    typingIndicatorEl = null;
    maybeScrollToBottom();
  }

  function appendErrorMessage(failedMessage: string, message = 'Erro ao processar a mensagem.'): void {
    const wasNearBottom = isUserNearBottom();

    const wrapper = document.createElement('div');
    wrapper.className = 'message-row is-assistant';
    wrapper.dataset.role = 'assistant';

    const bubble = document.createElement('div');
    bubble.className = 'message-bubble assistant-bubble error-bubble is-visible';

    const content = document.createElement('div');
    content.className = 'message-content';
    content.textContent = message;

    const actions = document.createElement('div');
    actions.className = 'error-actions';

    const retryBtn = document.createElement('button');
    retryBtn.type = 'button';
    retryBtn.className = 'retry-btn';
    retryBtn.textContent = 'Tentar novamente';

    retryBtn.addEventListener('click', () => {
      wrapper.remove();
      sendMessage(failedMessage, { isRetry: true });
    });

    actions.appendChild(retryBtn);
    bubble.appendChild(content);
    bubble.appendChild(actions);
    wrapper.appendChild(bubble);
    messagesContainer.appendChild(wrapper);

    if (wasNearBottom) {
      maybeScrollToBottom(true);
    }
  }

  function appendQuotaMessage(error: ChatApiError, failedMessage: string): void {
    const payload = error.payload || {};
    const usage = Number.isFinite(payload.usage) ? payload.usage : null;
    const limit = Number.isFinite(payload.limit) ? payload.limit : null;
    const hasUsage = typeof usage === 'number' && typeof limit === 'number';
    const upgradeUrl = payload.upgradeUrl || '/upgrade';
    const wasNearBottom = isUserNearBottom();

    const wrapper = document.createElement('div');
    wrapper.className = 'message-row is-assistant';
    wrapper.dataset.role = 'assistant';

    const bubble = document.createElement('div');
    bubble.className = 'message-bubble assistant-bubble quota-bubble is-visible';

    const content = document.createElement('div');
    content.className = 'message-content';
    content.textContent = hasUsage
      ? `Limite gratuito atingido: ${usage}/${limit}. Faça upgrade ou acesse sua conta para continuar.`
      : (payload.message || 'Limite de uso atingido. Faça upgrade ou acesse sua conta para continuar.');

    const actions = document.createElement('div');
    actions.className = 'error-actions';

    const upgradeBtn = document.createElement('button');
    upgradeBtn.type = 'button';
    upgradeBtn.className = 'retry-btn quota-action-primary';
    upgradeBtn.textContent = upgradeUrl.includes('signup') ? 'Criar conta' : 'Upgrade';
    upgradeBtn.addEventListener('click', () => {
      window.location.href = upgradeUrl;
    });

    const retryBtn = document.createElement('button');
    retryBtn.type = 'button';
    retryBtn.className = 'retry-btn';
    retryBtn.textContent = 'Tentar novamente';
    retryBtn.addEventListener('click', () => {
      wrapper.remove();
      sendMessage(failedMessage, { isRetry: true });
    });

    actions.appendChild(upgradeBtn);
    actions.appendChild(retryBtn);
    bubble.appendChild(content);
    bubble.appendChild(actions);
    wrapper.appendChild(bubble);
    messagesContainer.appendChild(wrapper);

    if (wasNearBottom) {
      maybeScrollToBottom(true);
    }
  }

  function handleChatApiError(error: unknown, failedMessage: string): boolean {
    if (!(error instanceof ChatApiError)) return false;

    if (error.status === 403 && error.payload?.error === 'Message limit reached') {
      showMarketingBarrier('message');
      return true;
    }

    if (error.status === 402 || (error.status === 403 && error.payload?.error === 'Daily quota exceeded')) {
      setComposerLocked(true);
      if (error.status === 403 && isGuestSession()) {
        showMarketingBarrier('quota');
      } else {
        appendQuotaMessage(error, failedMessage);
      }
      return true;
    }

    return false;
  }

  async function buildChatApiError(response: Response): Promise<ChatApiError> {
    const rawBody = await response.text();
    let payload: ApiErrorPayload | null = null;

    try {
      payload = JSON.parse(rawBody);
    } catch {
      payload = null;
    }

    console.error('[Chat] Erro na API. Status:', response.status, 'Body:', rawBody);
    return new ChatApiError(response.status, payload, rawBody);
  }

  function animateSendInteraction(): void {
    form.classList.remove('send-pressed');
    void form.offsetWidth;
    form.classList.add('send-pressed');

    sendBtn.classList.remove('is-firing');
    void sendBtn.offsetWidth;
    sendBtn.classList.add('is-firing');
    if (firingTimeout) {
      clearTimeout(firingTimeout);
    }
    firingTimeout = window.setTimeout(() => {
      sendBtn.classList.remove('is-firing');
    }, 420);
  }

  async function sendMessage(userMessage: string, opts: ChatOptions = {}): Promise<void> {
    if (isSending) return;

    if (quotaLocked) {
      if (isGuestSession()) {
        showMarketingBarrier('quota');
      } else {
        appendQuotaMessage(
          new ChatApiError(403, {
            error: 'Daily quota exceeded',
            message: 'Limite diário atingido. Faça upgrade para continuar.',
            usage: latestUsage?.today,
            limit: latestUsage?.limit,
            upgradeUrl: '/upgrade',
          }, ''),
          userMessage,
        );
      }
      return;
    }

    // Lógica de Marketing: 3 mensagens (Apenas para Guests reais)
    const isGuest = isGuestSession();
    const userMessagesCount = messages.filter(m => m.role === 'user').length;

    // Hardened: Se o usuário estiver logado (não for guest), ignoramos o limite de 3 mensagens.
    if (isGuest && userMessagesCount >= 3) {
      showMarketingBarrier('message');
      isSending = false;
      return;
    }

    isSending = true;

    if (!opts.isRetry) {
      animateSendInteraction();
      appendMessage('user', userMessage, { fromInput: true, forceScroll: true });
      messages.push({ role: 'user', content: userMessage });
    }

    showTypingIndicator();

    try {
      const token = await ensureSession();

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 45000); // 45s timeout no frontend

      const response = await fetch(`${apiUrl}/api/chat`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({
          messages,
          personaId: (document.getElementById('persona-select') as HTMLSelectElement)?.value || 'nox',
          stream: true,
        }),
        signal: controller.signal,
      });

      clearTimeout(timeoutId);

      if (response.status === 401) {
        clearAuthToken();
        throw new Error('Session expired');
      }

      if (!response.ok) {
        throw await buildChatApiError(response);
      }

      const reader = response.body?.getReader();
      if (!reader) {
        throw new Error('API response body ausente');
      }

      const decoder = new TextDecoder();
      const assistantId = `msg-ast-${Date.now()}`;

      let assistantContent = '';
      let isFirstChunk = true;
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        const decodedChunk = decoder.decode(value, { stream: true });
        buffer += decodedChunk;
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;

          const dataStr = line.slice(6);
          if (dataStr.trim() === '[DONE]') continue;

          try {
            const data = JSON.parse(dataStr);
            const textChunk = data.choices?.[0]?.delta?.content || '';
            if (!textChunk) continue;

            assistantContent += textChunk;

            if (isFirstChunk) {
              hideTypingIndicator();
              const inserted = appendMessage('assistant', assistantContent, {
                id: assistantId,
                streaming: true,
                forceScroll: true,
              });
              streamingBubble = inserted.bubble;
              isFirstChunk = false;
            } else {
              updateMessage(assistantId, assistantContent);
            }
          } catch (err) {
            console.error('[Chat] Falha no JSON.parse:', err);
          }
        }
      }

      if (streamingBubble) {
        streamingBubble.classList.remove('is-streaming');
      }

      messages.push({ role: 'assistant', content: assistantContent });
      saveHistory();
    } catch (err) {
      console.error('[Chat] Falha no envio:', err);
      hideTypingIndicator();
      if (streamingBubble) {
        streamingBubble.classList.remove('is-streaming');
        streamingBubble = null;
      }

      if (!handleChatApiError(err, userMessage)) {
        let message = 'Erro ao processar a mensagem.';
        if (err instanceof ChatApiError && err.payload?.message) {
          message = err.payload.message;
        } else if (err instanceof Error && (err.name === 'AbortError' || err.message?.includes('timeout'))) {
          message = 'O servidor demorou muito para responder. Tente novamente.';
        } else if (err instanceof TypeError && err.message.includes('fetch')) {
          message = 'Erro de conexão ou bloqueio de segurança (CORS). Verifique sua internet ou VPN.';
        }
        appendErrorMessage(userMessage, message);
      }
    } finally {
      isSending = false;
      hideTypingIndicator();
      if (!quotaLocked && !isMobileComposerMode()) {
        input.focus();
      }
      syncSendAvailability();
      updateQuota();
    }
  }

  async function updateQuota(allowAuthRetry = true) {
    try {
      const token = getStoredToken();
      if (!token) {
        await ensureSession();
      }
      const activeToken = getStoredToken();
      if (!activeToken) return;
      const response = await fetch(`${apiUrl}/api/usage`, {
        headers: { Authorization: `Bearer ${activeToken}` }
      });
      // Token expirado/inválido: descarta o token podre e refaz a sessão
      // de convidado uma única vez, evitando 403 recorrente no console.
      if (response.status === 401 || response.status === 403) {
        clearAuthToken();
        if (allowAuthRetry) {
          await ensureSession();
          return updateQuota(false);
        }
        return;
      }
      if (!response.ok) return;

      const data: UsagePayload = await response.json();
      latestUsage = data;
      isGuestAccess = data.plan === 'guest' || data.tier === 'guest';
      quotaSynced = true;
      const indicator = document.getElementById('quota-indicator');
      const count = indicator?.querySelector('.quota-count');
      if (count && indicator) {
        const limit = Number(data.limit || 0);
        const remaining = Number(data.remaining || 0);
        const balance = Number(data.balance ?? 0);
        const today = limit - remaining;
        const exhausted = isUsageExhausted(data);
        const safeToday = Number.isFinite(today) && Number.isFinite(limit) && limit > 0
          ? Math.min(Math.max(today, 0), limit)
          : today;
        const isProTier = data.tier === 'pro' || data.tier === 'premium' || data.plan === 'paid_pro';
        const shouldShowUpgrade = !isProTier && Number.isFinite(today) && Number.isFinite(limit) && limit > 0 && today >= limit * 0.8;

        if (balance > 0) {
          // Mostra o saldo direto no badge do chat
          count.textContent = String(balance);
        } else {
          count.textContent = `${safeToday}/${limit}`;
        }

        const upgradePrompt = document.getElementById('upgrade-prompt');
        const upgradeButton = upgradePrompt?.querySelector('button');
        if (upgradePrompt && upgradeButton instanceof HTMLButtonElement) {
          if (shouldShowUpgrade) {
            upgradeButton.textContent = isGuestAccess ? 'CADASTRO' : 'UPGRADE';
            upgradeButton.onclick = () => {
              window.location.href = isGuestAccess
                ? '/signup?reason=limit_warning'
                : '/upgrade';
            };
            upgradePrompt.style.display = 'block';
          } else {
            upgradePrompt.style.display = 'none';
          }
        }

        if (exhausted) {
          indicator.classList.add('is-exhausted');
          setComposerLocked(true);
          if (isGuestAccess) {
            showMarketingBarrier('quota');
          }
        } else {
          indicator.classList.remove('is-exhausted');
          setComposerLocked(false);
        }

        // Hack de Soberania: Ocultar seletor se não for Pro
        const personaContainer = document.getElementById('persona-container');
        if (personaContainer) {
          personaContainer.style.display = isProTier ? 'block' : 'none';
        }
      }
    } catch (err) {
      // Network/CORS failures should not break chat UX.
      console.warn(`[Quota] usage unavailable at ${apiUrl}/api/usage. Origin: ${window.location.origin}`, err);
    }
  }

  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = `${Math.min(input.scrollHeight, 170)}px`;
    syncSendAvailability();
  });

  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (input.value.trim() && !isSending) {
        form.requestSubmit();
      }
    }
  });

  form.addEventListener('submit', async (e: SubmitEvent) => {
    e.preventDefault();
    const userMessage = input.value.trim();
    if (!userMessage || isSending) return;

    input.value = '';
    input.style.height = 'auto';
    syncSendAvailability();

    if (isMobileComposerMode()) {
      input.blur();
    }

    await sendMessage(userMessage);
  });

  function showMarketingBarrier(reason: 'message' | 'quota' = 'message') {
    if (!marketingBarrierEl) return;
    const title = marketingBarrierEl.querySelector('h3');
    const copy = marketingBarrierEl.querySelector('p');
    if (reason === 'quota') {
      if (title) title.textContent = 'Créditos gratuitos encerrados';
      if (copy) copy.textContent = 'Crie sua conta para continuar usando o NØX.';
    } else {
      if (title) title.textContent = 'E aí, tá curtindo?';
      if (copy) copy.textContent = 'Dá uma moral e cria uma conta, é grátis.';
    }

    marketingBarrierEl.style.display = 'flex';
    input.blur();
    input.disabled = true;
    sendBtn.disabled = true;

    if (marketingRedirectTimeout) {
      window.clearTimeout(marketingRedirectTimeout);
    }

    // Animação de redirecionamento após 4.5 segundos
    marketingRedirectTimeout = window.setTimeout(() => {
      window.location.href = '/signup?reason=limit_reached';
    }, 4500);

    // Limpeza para View Transitions
    document.addEventListener('astro:before-preparation', () => {
      if (marketingRedirectTimeout) {
        window.clearTimeout(marketingRedirectTimeout);
        marketingRedirectTimeout = null;
      }
    }, { once: true });
  }

  function syncViewportHeight() {
    (window as any).__noxSyncViewport?.();
    const keyboardOpen = document.body.classList.contains('keyboard-open');

    if (keyboardOpen) {
      requestAnimationFrame(() => scrollToBottom(false));
    }
  }

  input.addEventListener('focus', () => {
    document.body.classList.add('chat-input-focused');
    syncViewportHeight();
    window.setTimeout(() => scrollToBottom(false), 120);
  });

  input.addEventListener('blur', () => {
    document.body.classList.remove('chat-input-focused');
    window.setTimeout(syncViewportHeight, 80);
  });

  messagesContainer.addEventListener('pointerdown', () => {
    if (document.activeElement === input) {
      input.blur();
    }
  }, { passive: true });

  window.visualViewport?.addEventListener('resize', syncViewportHeight);
  window.visualViewport?.addEventListener('scroll', syncViewportHeight);
  window.addEventListener('resize', syncViewportHeight);
  syncViewportHeight();

  ensureSession()
    .then(() => updateQuota())
    .catch((err) => {
      console.warn(`[Init] Session failed at ${apiUrl}/api/auth/guest. Origin: ${window.location.origin}`, err);
      return updateQuota();
    })
    .catch((err) => console.error('[Init] Critical failure in chat startup', err));

  requestAnimationFrame(() => scrollToBottom(false));

  // === Menu hambúrguer do header ===
  const menuToggle = document.getElementById('menu-toggle');
  const navMenu = document.getElementById('nav-menu');
  if (menuToggle instanceof HTMLButtonElement && navMenu instanceof HTMLElement) {
    const setMenu = (open: boolean) => {
      menuToggle.classList.toggle('is-open', open);
      navMenu.classList.toggle('is-open', open);
      menuToggle.setAttribute('aria-expanded', String(open));
      menuToggle.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
    };

    menuToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      setMenu(!navMenu.classList.contains('is-open'));
    });

    document.addEventListener('click', (e) => {
      if (!navMenu.classList.contains('is-open')) return;
      const target = e.target as Node;
      if (!navMenu.contains(target) && !menuToggle.contains(target)) setMenu(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navMenu.classList.contains('is-open')) {
        setMenu(false);
        menuToggle.focus();
      }
    });
  }
</script>

