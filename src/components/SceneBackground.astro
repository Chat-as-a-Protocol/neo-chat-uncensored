---
export interface Props {
  animateLogo?: boolean;
}
const { animateLogo = true } = Astro.props;
---

<div class="scene-lights" aria-hidden="true" transition:persist="scene-bg">
  <div class="grain"></div>
  <img src="/bg_escuro.webp" alt="" class="bg-wallpaper" />
  <div class="vignette"></div>
</div>

<style>
  .scene-lights {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: #000000;
    overflow: hidden;
  }

  .grain {
    position: absolute;
    inset: 0;
    opacity: 0.04; /* Mais sutil */
    background-image: radial-gradient(rgba(255, 255, 255, 0.4) 0.5px, transparent 0);
    background-size: 2px 2px;
    mix-blend-mode: overlay;
    z-index: 0;
  }

  .bg-wallpaper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    opacity: 0.5;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    border: none;
    outline: none;
  }

  .vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(to top, 
      rgba(0, 0, 0, 1) 0%, 
      rgba(0, 0, 0, 0.7) 40%, 
      rgba(0, 0, 0, 0) 100%
    );
  }
</style>
