---
export interface Props {
  animateLogo?: boolean;
}
const { animateLogo = true } = Astro.props;
---

<div class="scene-lights" aria-hidden="true" transition:persist="scene-bg">
  <div class="grain"></div>
  <img src="/bg_escuro.webp" alt="" class="bg-wallpaper" />
  <img src="/neoai.png" alt="" class={`floating-logo ${animateLogo ? '' : 'no-anim'}`} />
  <div class="vignette"></div>
</div>

<style>
  .scene-lights {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: #000000;
    overflow: hidden;
  }

  .grain {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    background-image: radial-gradient(rgba(255, 255, 255, 0.6) 0.6px, transparent 0);
    background-size: 3px 3px;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .bg-wallpaper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    opacity: 1;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    border: none;
    outline: none;
  }

  .floating-logo {
    position: absolute;
    top: 24%; /* Subindo a logo ainda mais para abrir espaço para o modal alto de signup */
    left: 50%;
    width: 150vw;
    min-width: 1200px;
    max-width: none;
    height: auto;
    object-fit: contain;
    opacity: 0.95; /* Quase 100%, com leve respiro para o wallpaper interagir */
    pointer-events: none;
    user-select: none;
    z-index: 2; /* Fica acima do wallpaper e abaixo da vinheta */
    border: none;
    outline: none;
    filter: drop-shadow(0 40px 60px rgba(0, 0, 0, 0.65)); /* Sombra forte para descolar do fundo e dar profundidade 3D */
    animation: float-logo 12s ease-in-out infinite;
  }

  @keyframes float-logo {
    0%, 100% {
      transform: translate(-50%, -48%) rotate(-0.5deg);
    }
    50% {
      transform: translate(-50%, -52%) rotate(0.5deg);
    }
  }

  .floating-logo.no-anim {
    animation: none !important;
    transform: translate(-50%, -50%);
  }

  .vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 58%, rgba(0, 0, 0, 0.82) 100%);
  }
</style>
