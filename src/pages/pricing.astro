---
import Layout from '../layouts/Layout.astro';
import plans from '../../shared/plans.json';

const packages = Object.entries(plans.packages || {}).map(([id, pkg]) => ({ id, ...pkg }));


const brl = (value: number) =>
  new Intl.NumberFormat('pt-BR', {
    style: 'currency',
    currency: 'BRL',
    maximumFractionDigits: 0,
  }).format(value);
---

<Layout title="Preços · NØX">
  <main class="pricing-shell">
    <header class="pricing-header">
      <a href="/" class="back-link" aria-label="Voltar ao terminal">←</a>
      <img src="/nox_vert.webp" alt="NØX" class="nox-logo" />
      <h1>Preços</h1>
      <p>Acesso pago, ledger auditável e pacotes claros antes do cadastro.</p>
    </header>

    <section class="price-list" aria-label="Pacotes de tokens">
      {packages.map((pkg) => (
        <article class={`price-card ${pkg.id === '5k' ? 'is-featured' : ''} ${pkg.id === '10k' ? 'is-pro' : ''}`}>
          <div class="card-top">
            <div>
              {pkg.id === '5k' && <span class="badge">Melhor valor</span>}
              {pkg.id === '10k' && <span class="badge">P.R.O</span>}
              <h2>{pkg.name}</h2>
              <p>{pkg.tokens.toLocaleString('pt-BR')} NØX</p>
            </div>
            <strong>{brl(pkg.price)}</strong>
          </div>

          <ul>
            {pkg.benefits.map((benefit) => (
              <li>{benefit}</li>
            ))}
          </ul>

          <a href="/signup" class="price-action">Criar conta para ativar</a>
        </article>
      ))}
    </section>



    <footer class="pricing-footer">
      <a href="/login">Já tenho conta</a>
      <span>·</span>
      <a href="/terms-and-conditions">Termos</a>
      <span>·</span>
      <a href="/privacy-policy">Privacidade</a>
    </footer>
  </main>
</Layout>

<style>
  .pricing-shell {
    min-height: 100svh;
    position: relative;
    isolation: isolate;
    padding: max(18px, env(safe-area-inset-top)) 16px max(22px, env(safe-area-inset-bottom));
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.28), rgba(0, 0, 0, 0.76)),
      url('/bg_claro.webp') center/cover no-repeat;
    color: #fff;
    overflow-y: auto;
  }

  .pricing-header {
    width: 100%;
    max-width: 480px;
    margin: 0 auto 14px;
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    align-items: center;
    gap: 10px;
    text-align: center;
  }

  .back-link {
    width: 38px;
    height: 38px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.88);
    background: rgba(13, 15, 18, 0.48);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 22px;
    line-height: 1;
  }

  .nox-logo {
    justify-self: center;
    width: min(190px, 58vw);
    height: auto;
    object-fit: contain;
  }

  .pricing-header h1,
  .pricing-header p {
    grid-column: 1 / -1;
  }

  .pricing-header h1 {
    margin-top: 2px;
    font-size: 28px;
    line-height: 1;
  }

  .pricing-header p {
    margin: 8px auto 0;
    max-width: 340px;
    color: rgba(245, 247, 250, 0.74);
    font-size: 14px;
    line-height: 1.45;
  }

  .price-list {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .product-list {
    margin-top: 12px;
  }

  .price-card {
    width: 100%;
    padding: 18px;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
      rgba(14, 16, 18, 0.76);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.28);
  }

  .price-card.is-featured,
  .price-card.is-pro,
  .price-card.is-product {
    border-color: rgba(185, 214, 49, 0.58);
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 12px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    min-height: 22px;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(185, 214, 49, 0.18);
    color: var(--accent);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h2 {
    margin: 8px 0 3px;
    color: rgba(255, 255, 255, 0.96);
    font-size: 21px;
    line-height: 1.08;
  }

  .card-top p {
    margin: 0;
    color: var(--accent);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-top strong {
    color: #fff;
    font-size: 22px;
    line-height: 1;
    white-space: nowrap;
  }

  ul {
    margin: 0 0 16px;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  li {
    color: rgba(245, 247, 250, 0.78);
    font-size: 13px;
    line-height: 1.38;
  }

  li::before {
    content: '•';
    color: var(--accent);
    margin-right: 8px;
  }

  .price-action {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 999px;
    background: var(--accent);
    color: #111;
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pricing-footer {
    width: 100%;
    max-width: 480px;
    margin: 18px auto 0;
    padding-bottom: 6px;
    display: flex;
    justify-content: center;
    gap: 10px;
    color: rgba(245, 247, 250, 0.56);
    font-size: 13px;
  }

  .pricing-footer a {
    color: rgba(245, 247, 250, 0.72);
  }
</style>
