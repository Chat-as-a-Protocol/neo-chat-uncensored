---
import Layout from '../layouts/Layout.astro';

const token = Astro.cookies.get('nox_token')?.value;

if (!token) {
  return Astro.redirect('/login');
}
---

<Layout title="Conta · NØX">
  <main class="account-shell">
    <img src="/nox_vert.webp" alt="NØX" class="panel-logo-bg" />
    <section class="account-panel" aria-labelledby="account-title">
      <a href="/" class="back-link">← Terminal</a>

      <div class="account-heading">
        <h1 id="account-title">Conta</h1>
      </div>

      <dl class="account-stats">
        <div>
          <dt>Plano</dt>
          <dd id="account-plan">--</dd>3
        </div>
        <div>
          <dt>Uso hoje</dt>
          <dd id="account-usage">--/--</dd>
        </div>
        <div>
          <dt>Disponível</dt>
          <dd id="account-remaining">--</dd>
        </div>
        <div>
          <dt>Saldo NØX</dt>
          <dd id="account-balance">--</dd>
        </div>
      </dl>

      <p id="account-status" class="account-status">Carregando conta...</p>

      <div class="account-actions">
        <a href="/upgrade" class="primary-action">Upgrade</a>
        <button id="logout-button" type="button" class="secondary-action">Sair</button>
      </div>
    </section>
  </main>
</Layout>

<script>
  const productionApiUrl = 'https://api.noxai.chat';
  const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
  const configuredApiUrl = String(import.meta.env.PUBLIC_API_URL || '').trim().replace(/\/$/, '');
  const configuredApiIsLocal = /^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i.test(configuredApiUrl);
  const apiUrl = configuredApiUrl && (isLocalhost || !configuredApiIsLocal)
    ? configuredApiUrl
    : (isLocalhost ? 'http://localhost:3001' : productionApiUrl);
  const accountPlanEl = document.getElementById('account-plan');
  const accountUsageEl = document.getElementById('account-usage');
  const accountRemainingEl = document.getElementById('account-remaining');
  const accountBalanceEl = document.getElementById('account-balance');
  const accountStatusEl = document.getElementById('account-status');
  const logoutButton = document.getElementById('logout-button');
  const tokenStorageKey = 'nox_token';

  function clearAuthToken() {
    localStorage.removeItem(tokenStorageKey);
    document.cookie = `${tokenStorageKey}=; path=/; max-age=0; SameSite=Lax`;
  }

  function getAuthToken() {
    return localStorage.getItem(tokenStorageKey);
  }

  function setPlanStatus(tier: string) {
    if (!accountStatusEl) return;
    
    const benefits = {
      'guest': 'Modo degustação: 500 tokens diários e 3 interações por conversa.',
      'free': 'Usuário Identificado: 1.000 tokens diários e histórico de chat salvo.',
      'paid_basic': 'Plano Basic: 5.000 tokens diários e acesso ampliado.',
      'paid_pro': 'Status ELITE: Acesso total ao núcleo NØX e suporte de arquitetura.'
    };

    const key = tier.includes('pro') ? 'paid_pro' : 
                tier.includes('basic') ? 'paid_basic' : 
                tier.includes('free') ? 'free' : 'guest';
                
    accountStatusEl.textContent = benefits[key] || 'Conta ativa e sincronizada.';
    accountStatusEl.style.opacity = '1';
    accountStatusEl.style.color = 'rgba(255, 255, 255, 0.8)';
  }

  function formatPlan(plan?: string, tier?: string) {
    const value = plan || tier || 'guest';
    if (value === 'guest') return 'Free';
    if (value === 'paid_basic') return 'Basic';
    if (value === 'paid_pro') return 'P.R.O';
    return value;
  }

  async function loadAccount() {
    const token = getAuthToken();
    if (!token) {
      window.location.href = '/login';
      return;
    }

    try {
      const usageResponse = await fetch(`${apiUrl}/api/usage`, {
        headers: { Authorization: `Bearer ${token}` },
      });

      if (usageResponse.status === 401) {
        clearAuthToken();
        window.location.href = '/login';
        return;
      }

      if (!usageResponse.ok) {
        setStatus('Não foi possível carregar a conta agora.');
        return;
      }

      const usage = await usageResponse.json();
      const remaining = Math.max(0, Number(usage.remaining || 0));
      const planValue = formatPlan(usage.plan, usage.tier);
      const isPro = planValue.includes('P.R.O');

      if (accountPlanEl) {
        accountPlanEl.textContent = planValue;
        if (isPro) {
          accountPlanEl.classList.add('pro-glow');
          document.querySelector('.account-panel')?.classList.add('is-pro');
          const upgradeBtn = document.querySelector('.primary-action');
          if (upgradeBtn) {
            upgradeBtn.textContent = 'Comunidade';
            upgradeBtn.setAttribute('href', 'https://t.me/nox_ia');
          }
        }
      }
      
      if (accountUsageEl) accountUsageEl.textContent = `${usage.today}/${usage.limit}`;
      if (accountRemainingEl) accountRemainingEl.textContent = String(remaining);

      try {
        const ledgerResponse = await fetch(`${apiUrl}/api/ledger`, {
          headers: { Authorization: `Bearer ${token}` },
        });

        if (ledgerResponse.ok) {
          const ledger = await ledgerResponse.json();
          if (accountBalanceEl) accountBalanceEl.textContent = String(ledger.balance ?? 0);
        }
      } catch {
        if (accountBalanceEl) accountBalanceEl.textContent = '--';
      }

      setPlanStatus(usage.tier || usage.plan || 'guest');
    } catch {
      setStatus('Conexão indisponível. Tente novamente em instantes.');
    }
  }

  logoutButton?.addEventListener('click', () => {
    clearAuthToken();
    window.location.href = '/login';
  });

  loadAccount();
</script>

<style>
  .account-shell {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px;
    background: url('/bg_claro.webp') center/cover no-repeat;
    background-color: #000;
  }

  .panel-logo-bg {
    position: absolute;
    right: calc(50% - 240px);
    top: calc(50% - 250px);
    height: 140px;
    width: auto;
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.2));
    z-index: 1; /* Fica atrás do painel */
    pointer-events: none;
    opacity: 0.9;
    transform: rotate(4deg);
  }

  .account-panel {
    position: relative;
    z-index: 2; /* Fica à frente da logo para gerar a refração */
    width: 100%;
    max-width: 430px;
    padding: 30px 24px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 22px;
    background: rgba(12, 14, 20, 0.6);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.58);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
  }

  .pro-glow {
    color: var(--accent) !important;
    text-shadow: 0 0 15px rgba(185, 214, 49, 0.6);
  }

  .is-pro {
    border-color: rgba(185, 214, 49, 0.25) !important;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.86rem;
  }

  .account-heading {
    margin-bottom: 24px;
  }

  .eyebrow {
    display: block;
    margin-bottom: 4px;
    color: var(--accent);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  h1 {
    color: #fff;
    font-size: 2.2rem;
  }

  .account-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: 0;
  }

  .account-stats div {
    min-width: 0;
    padding: 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.28);
  }

  dt {
    margin-bottom: 6px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.74rem;
  }

  dd {
    margin: 0;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.12rem;
    font-weight: 700;
  }

  .account-status {
    min-height: 20px;
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.86rem;
  }

  .account-actions {
    display: flex;
    gap: 10px;
    margin-top: 22px;
  }

  .primary-action,
  .secondary-action {
    flex: 1;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    cursor: pointer;
  }

  .primary-action {
    color: #101204;
    background: var(--accent);
  }

  .secondary-action {
    color: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 420px) {
    .account-stats {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 1.9rem;
    }
  }
</style>
