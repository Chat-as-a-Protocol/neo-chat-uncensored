---
import Layout from '../layouts/Layout.astro';

const token = Astro.cookies.get('neo_token')?.value;

if (!token) {
  return Astro.redirect('/login');
}
---

<Layout title="NØX.AI - Upgrade">
  <div class="upgrade-container">
    <div class="upgrade-glass">
      <div class="upgrade-header">
        <div class="logo-title">
          <img src="/nox_vert.webp" alt="NØX" class="nox-logo" />
          <h1 class="white-text">Upgrade</h1>
        </div>
      </div>
           <div class="pricing-grid">
        <!-- Token Packs -->
        <div class="price-card tier-tokens">
          <h3>Token Packs</h3>
          <div class="usage-hint">
            <p><strong>Free/Basic:</strong> Compre tokens para uso imediato</p>
          </div>
          <div class="tokens-grid">
            <div class="token-item">
              <div class="token-amount">1k</div>
              <div class="token-price">R$ 19</div>
              <button onclick="buyTokens('1k')" class="btn-token">Buy</button>
            </div>
            <div class="token-item">
              <div class="token-amount">5k</div>
              <div class="token-price">R$ 79</div>
              <button onclick="buyTokens('5k')" class="btn-token">Buy</button>
            </div>
            <div class="token-item">
              <div class="token-amount">10k</div>
              <div class="token-price">R$ 149</div>
              <button onclick="buyTokens('10k')" class="btn-token">Buy</button>
            </div>
          </div>
        </div>

        <!-- Pro Plan -->
        <div class="price-card tier-pro active">
          <div class="badge">Acesso Total</div>
          <h3>Pro Engine</h3>
          <div class="usage-hint">
            <p><strong>Pro:</strong> Já inclui uso prioritário + modelos exclusivos</p>
          </div>
          <div class="price">R$ 49<span>/mês</span></div>
          <ul class="features">
            <li>Alta Capacidade Diária (10k)</li>
            <li>Todos os modelos Pro</li>
            <li>Deep Analysis Ativo</li>
          </ul>
          <button onclick="handleFlowPay()" class="btn-primary">Subscribe</button>
        </div>
      </div>
      
      <a href="/" style="color: white;" class="back-link">←Return</a>

      <!-- FlowPay Diagnostics Panel -->
      <div class="test-panel" id="flowpay-test">
        <div class="test-header">
          <span class="test-title">Sovereign Payment Diagnostics</span>
          <button onclick="checkFlowHealth()" class="btn-check">Check API</button>
        </div>
        <div id="health-status" class="health-status"></div>
        <hr class="test-divider" />
        <button onclick="testFlowCharge()" class="btn-test">Simulate Test Charge (R$ 1.00)</button>
        <div id="test-result" class="test-result"></div>
      </div>
    </div>
  </div>

  <style>
    .upgrade-container {
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: url('/bg_claro.webp') center/cover no-repeat;
      background-color: #000;
      font-family: 'Space Grotesk', sans-serif;
    }

    .upgrade-glass {
      width: 100%;
      max-width: 480px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: linear-gradient(145deg, rgba(20, 20, 25, 0.35) 0%, rgba(10, 10, 15, 0.15) 100%);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 22px;
      padding: 40px 30px;
      text-align: center;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
    }

    .nox-logo {
      height: 80px;
      width: auto;
      margin-bottom: 8px;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 12px;
      margin-bottom: 20px;
    }

    .price-card {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      padding: 16px 12px;
      display: flex;
      flex-direction: column;
      text-align: left;
    }

    .price-card.active {
      border-color: var(--accent);
      background: rgba(0, 0, 0, 0.6);
    }

    .price-card h3 {
      font-size: 1rem;
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      opacity: 0.8;
    }

    .usage-hint {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      padding: 10px;
      margin: 10px 0;
      font-size: 0.75rem;
      border-left: 3px solid var(--accent);
      text-align: left;
    }

    .usage-hint p {
      margin: 0;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.8);
    }

    .tokens-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    /* Diagnostics Panel Styles */
    .test-panel {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 20px;
      margin-top: 40px;
      font-family: 'Space Grotesk', sans-serif;
    }

    .test-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .test-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.5);
    }

    .btn-check, .btn-test {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: white;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-test {
      width: 100%;
      background: rgba(var(--accent-rgb), 0.1);
      border-color: var(--accent);
      color: var(--accent);
      font-weight: bold;
    }

    .btn-check:hover, .btn-test:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .health-status, .test-result {
      font-family: monospace;
      font-size: 0.75rem;
      margin: 10px 0;
    }

    .test-divider {
      border: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      margin: 15px 0;
    }

    .success { color: #00ffaa; }
    .error { color: #ff4444; }
    .loading { color: #aaa; font-style: italic; }

    .success-box {
      background: rgba(0, 255, 170, 0.1);
      border: 1px solid rgba(0, 255, 170, 0.2);
      padding: 12px;
      border-radius: 8px;
      text-align: center;
    }

    .btn-checkout {
      display: block;
      width: 100%;
      margin-top: 10px;
      background: #00ffaa;
      color: #000;
      border: none;
      padding: 8px;
      border-radius: 4px;
      font-weight: bold;
      cursor: pointer;
    }



    .token-item {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 12px 4px;
      text-align: center;
    }

    .token-amount {
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--accent);
      font-family: 'Space Grotesk', monospace;
    }

    .token-price {
      font-size: 0.75rem;
      margin: 4px 0 10px 0;
      opacity: 0.6;
    }

    .btn-token {
      width: 100%;
      padding: 6px;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.05);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 0.7rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-token:hover {
      background: var(--accent);
      color: black;
      border-color: var(--accent);
    }

    .price {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .price span {
      font-size: 0.8rem;
      opacity: 0.5;
    }

    .badge {
      align-self: flex-start;
      background: var(--accent);
      color: #000;
      font-size: 8px;
      font-weight: 800;
      padding: 2px 8px;
      border-radius: 4px;
      margin-bottom: 8px;
    }

    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 16px 0;
    }

    .features li {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.6);
      margin-bottom: 4px;
    }

    .btn-primary {
      background: var(--accent);
      border: none;
      color: #000;
      padding: 12px;
      border-radius: 10px;
      font-weight: 800;
      cursor: pointer;
    }

    .back-link {
      margin-top: 15px;
      color: rgba(255,255,255,0.3);
      font-size: 0.8rem;
    }

    @media (max-width: 480px) {
      .pricing-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline define:vars={{ 
    PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL,
    isLocalhost: ['localhost', '127.0.0.1'].includes(Astro.url.hostname) 
  }}>
    const apiUrl = PUBLIC_API_URL || (isLocalhost ? 'http://localhost:3001' : 'https://backend-vit.up.railway.app');
    const API_URL = isLocalhost ? 'http://localhost:3001' : '';

    window.checkFlowHealth = async function() {
      const token = localStorage.getItem('neo_token');
      const statusEl = document.getElementById('health-status');
      statusEl.innerHTML = '<span class="loading">Probing API...</span>';
      
      try {
        const res = await fetch(`${API_URL}/api/flowpay/health`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        statusEl.innerHTML = data.status === 'online' 
          ? `<span class="success">● FlowPay Online (${data.statusCode})</span>`
          : `<span class="error">● FlowPay Offline</span>`;
      } catch (err) {
        statusEl.innerHTML = `<span class="error">● Error: ${err.message}</span>`;
      }
    }

    window.testFlowCharge = async function() {
      const token = localStorage.getItem('neo_token');
      const resultEl = document.getElementById('test-result');
      resultEl.innerHTML = '<span class="loading">Creating sandbox charge...</span>';
      
      try {
        const res = await fetch(`${API_URL}/api/flowpay/test-charge`, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}` 
          }
        });
        const data = await res.json();
        if (data.success) {
          resultEl.innerHTML = `
            <div class="success-box">
              <p>✅ Test Charge Created</p>
              <small>ID: ${data.chargeId}</small>
              <button onclick="window.open('${data.checkoutUrl}', '_blank')" class="btn-checkout">Open Test Checkout</button>
            </div>
          `;
        } else {
          resultEl.innerHTML = `<div class="error-box">❌ ${data.error}</div>`;
        }
      } catch (err) {
        resultEl.innerHTML = `<div class="error-box">❌ ${err.message}</div>`;
      }
    }

    window.buyTokens = async function(packageType) {
      const token = localStorage.getItem('neo_token');
      if (!token) return window.location.href = '/login';
      
      try {
        const response = await fetch(`${apiUrl}/api/tokens/purchase`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ package: packageType })
        });
        
        const data = await response.json();
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Connection error. Please try again.');
      }
    }

    window.handleFlowPay = async function() {
      const token = localStorage.getItem('neo_token');
      if (!token) return window.location.href = '/login';
      
      try {
        const response = await fetch(`${apiUrl}/api/flowpay/create-charge`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json'
          }
        });
        
        const data = await response.json();
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert('Erro: ' + (data.error || 'Falha ao iniciar pagamento'));
        }
      } catch (err) {
        alert('Erro de conexão: ' + err.message);
      }
    }
  </script>
</Layout>