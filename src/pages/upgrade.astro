---
import Layout from '../layouts/Layout.astro';
---

<Layout title="NØX.ai - Upgrade">
  <div class="upgrade-container">
    <div class="upgrade-glass">
      <div class="upgrade-header">
        <div class="logo-title">
          <img src="/nox_vert.webp" alt="NØX" class="nox-logo" />
          <h1 class="white-text">Upgrade</h1>
        </div>
      </div>
      
      <div class="pricing-grid">
        <!-- Free Plan -->
        <div class="price-card tier-free">
          <h3>Standard</h3>
          <div class="price">R$ 0<span>/ciclo</span></div>
          <ul class="features">
            <li>100 processamentos/dia</li>
            <li>NØX Engine Base</li>
            <li>Latência normal</li>
          </ul>
          <button class="btn-disabled" disabled>Nível Atual</button>
        </div>

        <!-- Pro Plan -->
        <div class="price-card tier-pro active">
          <div class="badge">Recomendado</div>
          <h3>Pro Engine</h3>
          <div class="price">R$ 49<span>/ciclo</span></div>
          <ul class="features">
            <li>Processamento Ilimitado</li>
            <li>Todos os modelos Premium</li>
            <li>Deep Analysis Ativo</li>
            <li>Suporte Prioritário</li>
          </ul>
          <button onclick="handleFlowPay()" class="btn-primary">Ativar Upgrade</button>
        </div>
      </div>
      
      <a href="/" style="color: white;" class="back-link">←Return</a>
    </div>
  </div>

  <style>
    .upgrade-container {
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: url('/bg_claro.webp') center/cover no-repeat;
      background-color: #000;
      font-family: 'Space Grotesk', sans-serif;
    }

    .upgrade-glass {
      width: 100%;
      max-width: 100%;
      min-height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      /* Efeito de Vidro Grosso (Thick Frosted Glass) */
      background: linear-gradient(145deg, rgba(20, 20, 25, 0.35) 0%, rgba(10, 10, 15, 0.15) 100%);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-top: 1px solid rgba(255, 255, 255, 0.35);
      border-left: 1px solid rgba(255, 255, 255, 0.25);
      backdrop-filter: blur(4px) saturate(120%); /* Desfoque quase zerado */
      -webkit-backdrop-filter: blur(2px) saturate(120%);
      border-radius: 22px; /* Raio padrão Apple */
      padding: 50px 50px;
      text-align: center;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6), inset 0 0 40px rgba(255, 255, 255, 0.05);
    }

    .upgrade-header h1 {
      font-size: 1.0rem; /* Texto upgrade hiper-discreto */
      font-weight: 600;
      margin-bottom: 0;
      letter-spacing: 0.3em; /* Espaçado, estilo Apple */
      text-transform: uppercase;
      line-height: 1.1;
      opacity: 0.9; /* Voltou mais forte */
      text-shadow: 0 2px 30px rgba(0, 0, 0, 0.8), 0 2px 4px rgba(0, 0, 0, 0.5); /* Sombra agressiva para destaque */
    }

    .logo-title {
      display: flex;
      flex-direction: column; /* Empilhando Logo e Texto */
      align-items: center;
      justify-content: center;
      gap: 4px; /* Mais próximos */
      margin-bottom: 8px;
    }

    .nox-logo {
      height: 100px; /* Logo gigante estourada */
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 10px 20px rgba(0,0,0,0.5)); /* Refração natural */
    }

    .white-text {
      color: #ffffff;
      text-shadow: 0 4px 24px rgba(255, 255, 255, 0.4);
    }

    .upgrade-header p {
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.95rem; /* Reduzido */
      margin-bottom: 24px; /* Menos margem */
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px; /* Gap de mobile para caber os 2 cards na tela 9:16 */
      margin-bottom: 20px;
    }

    .price-card {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      padding: 16px 12px; /* Reduzido para caber lado a lado no 9:16 */
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
    }

    .price-card.active {
      border-color: rgba(206, 229, 92, 0.4);
      background: rgba(0, 0, 0, 0.6);
      box-shadow: inset 0 0 20px rgba(206, 229, 92, 0.05);
      transform: translateY(-2px);
    }

    .badge {
      align-self: center;
      background: var(--accent);
      color: #000;
      font-size: 9px;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: 99px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .price-card h3 {
      font-size: 1.1rem; /* Ajuste para o 9:16 */
      margin-bottom: 6px;
    }

    .price {
      font-size: 1.8rem; /* Ajuste para o 9:16 */
      font-weight: 700;
      margin-bottom: 16px;
    }

    .price span {
      font-size: 0.85rem;
      opacity: 0.5;
    }

    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 20px 0;
      text-align: left;
      flex: 1;
    }

    .features li {
      margin-bottom: 8px;
      font-size: 0.85rem; /* Menor para caber perfeitamente */
      color: rgba(255,255,255,0.7);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .features li::before {
      content: '→';
      color: var(--accent);
    }

    button {
      width: 100%;
      padding: 12px; /* Reduzido */
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;
    }

    .btn-primary {
      background: var(--accent);
      border: none;
      color: #000;
    }

    .btn-primary:hover {
      transform: scale(1.02);
      box-shadow: 0 0 20px rgba(206, 229, 92, 0.4);
    }

    .btn-disabled {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.3);
      cursor: default;
    }

    .back-link {
      display: inline-block;
      margin-top: 15px; /* Reduzido */
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      font-size: 0.85rem;
    }

    .back-link:hover {
      color: #fff;
    }

    @media (max-width: 768px) {
      .pricing-grid {
        grid-template-columns: 1fr 1fr; /* Mantendo lado a lado para caber numa tela só */
        gap: 8px; /* Menos espaço entre os cards no celular */
      }
      .upgrade-glass {
        padding: 20px 10px; /* Padding super reduzido no celular */
      }
      .features li {
        font-size: 0.75rem; /* Ajuste fino de texto para o celular */
      }
      .price {
        font-size: 1.8rem;
      }
      .upgrade-header h1 {
        font-size: 1.2rem; /* Texto upgrade ainda menor no celular */
      }
    }
  </style>

  <script is:inline>
    const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
    const apiUrl = import.meta.env.PUBLIC_API_URL || (isLocalhost ? 'http://localhost:3001' : window.location.origin);

    async function handleFlowPay() {
      const token = localStorage.getItem('neo_token');
      if (!token) {
        window.location.href = '/login';
        return;
      }
      
      try {
        const response = await fetch(`${apiUrl}/api/flowpay/create-charge`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json'
          }
        });
        
        if (!response.ok) {
          const errData = await response.json();
          throw new Error(errData.error || 'Falha ao iniciar pagamento');
        }
        
        const { checkoutUrl } = await response.json();
        window.location.href = checkoutUrl;
      } catch (err) {
        console.error('[FlowPay] Error:', err);
        alert('Erro ao processar pagamento: ' + err.message);
      }
    }
  </script>
</Layout>