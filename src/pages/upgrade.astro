---
import Layout from '../layouts/Layout.astro';
import plans from '../../shared/plans.json';

const token = Astro.cookies.get('nox_token')?.value;

if (!token) {
  return Astro.redirect('/login');
}

const packages = Object.entries(plans.packages || {}).map(([id, pkg]) => ({ id, ...pkg }));

---

<Layout title="NØX - Upgrade">
  <div class="upgrade-container">
    <main class="upgrade-shell">
      <header class="upgrade-header">
        <a href="/" class="back-link" aria-label="Voltar para chat">←</a>
        <img src="/nox_vert.webp" alt="NØX" class="nox-logo" />
        <h1>Upgrade</h1>
      </header>

      <section class="plans-stack" aria-label="Pacotes de tokens">
        {packages.map((pkg) => (
          <article class={`plan-card ${pkg.id === '10k' ? 'is-pro' : ''} ${pkg.id === '5k' ? 'is-popular' : ''}`}>
            <div class="plan-head">
              <div>
                {pkg.id === '5k' && <span class="badge best-value">Melhor valor</span>}
                {pkg.id === '10k' && <span class="badge pro-badge">Pro</span>}
                <h2>{pkg.name}</h2>
                <p>{pkg.tokens.toLocaleString()} tokens</p>
              </div>
              <strong class="price">R$ {pkg.price}</strong>
            </div>
            
            <ul class="features">
              {pkg.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>

            <button onclick={`buyTokens('${pkg.id}', this)`} class="btn-token">
              {pkg.id === '10k' ? 'ASCENDER' : 'ATIVAR'}
            </button>
          </article>
        ))}
      </section>



      <section class="pix-result" id="pix-result" hidden aria-live="polite">
        <div class="pix-result-head">
          <div>
            <span class="badge pro-badge">FlowPay Pix</span>
            <h2>Cobranca gerada</h2>
          </div>
          <button type="button" class="pix-close" onclick="closePixResult()" aria-label="Fechar Pix">×</button>
        </div>
        <img id="pix-qr" class="pix-qr" alt="QR Code Pix" hidden />
        <label for="pix-code" class="pix-label">Pix copia e cola</label>
        <input type="text" id="pix-code" class="pix-code" readonly />
        <button type="button" class="btn-token" onclick="copyPixCode(this)">COPIAR PIX</button>
        <p id="pix-meta" class="pix-meta"></p>
      </section>

      {import.meta.env.PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS === 'true' && (
        <div class="test-panel" id="flowpay-test">
          <div class="test-header">
            <span class="test-title">Sovereign Payment Diagnostics</span>
            <button onclick="checkFlowHealth()" class="btn-check">Check API</button>
          </div>
          <div id="health-status" class="health-status"></div>
          <hr class="test-divider" />
          <button onclick="testFlowCharge()" class="btn-test">Simulate Test Charge (R$ 1.00)</button>
          <div id="test-result" class="test-result"></div>
        </div>
      )}
    </main>
  </div>

  <style>
    .upgrade-container {
      height: 100%;
      min-height: 100%;
      position: relative;
      isolation: isolate;
      padding: max(18px, env(safe-area-inset-top)) 16px max(22px, env(safe-area-inset-bottom));
      background: url('/bg_claro.webp') center/cover no-repeat;
      background-color: #000;
      font-family: 'Space Grotesk', sans-serif;
      overflow-y: auto;
    }

    .upgrade-container::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(180deg, rgba(6, 7, 10, 0.36), rgba(6, 7, 10, 0.78)),
        rgba(220, 226, 220, 0.2);
    }

    .upgrade-shell {
      width: 100%;
      max-width: 480px;
      min-height: 100%;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 0 2px 12px;
    }

    .upgrade-header {
      z-index: 10;
      display: grid;
      grid-template-columns: 44px 1fr 44px;
      align-items: center;
      gap: 10px;
      padding: 8px 0 12px;
    }

    .back-link {
      width: 38px;
      height: 38px;
      display: inline-grid;
      place-items: center;
      border-radius: 999px;
      color: rgba(255, 255, 255, 0.88);
      background: rgba(13, 15, 18, 0.48);
      border: 1px solid rgba(255, 255, 255, 0.16);
      font-size: 22px;
      line-height: 1;
    }

    .nox-logo {
      justify-self: center;
      width: 180px;
      height: auto;
      object-fit: contain;
    }

    .upgrade-header h1 {
      grid-column: 1 / -1;
      margin: -4px 0 0;
      color: rgba(255, 255, 255, 0.94);
      font-size: 5px;
      font-weight: 700;
      text-align: center;
    }

    .plans-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .products-stack {
      padding-top: 2px;
    }

    .plan-card {
      width: 100%;
      padding: 18px;
      border-radius: 26px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
        rgba(18, 21, 24, 0.72);
      color: #fff;
    }

    .plan-card.is-popular,
    .plan-card.is-pro,
    .plan-card.is-product {
      border-color: rgba(185, 214, 49, 0.58);
    }

    .plan-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 14px;
    }

    .plan-head h2 {
      margin: 8px 0 3px;
      color: rgba(255, 255, 255, 0.95);
      font-size: 21px;
      line-height: 1.08;
      font-weight: 760;
      letter-spacing: 0;
    }

    .plan-head p {
      margin: 0;
      color: var(--accent);
      font-size: 14px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .usage-hint {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      padding: 10px;
      margin: 10px 0;
      font-size: 0.75rem;
      border-left: 3px solid var(--accent);
      text-align: left;
    }

    .usage-hint p {
      margin: 0;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.8);
    }

    .tokens-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    /* Diagnostics Panel Styles */
    .test-panel {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 20px;
      margin-top: 40px;
      font-family: 'Space Grotesk', sans-serif;
    }

    .test-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .test-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.5);
    }

    .btn-check, .btn-test {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: white;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.75rem;
      cursor: pointer;
    }

    .btn-test {
      width: 100%;
      background: rgba(var(--accent-rgb), 0.1);
      border-color: var(--accent);
      color: var(--accent);
      font-weight: bold;
    }

    .health-status, .test-result {
      font-family: monospace;
      font-size: 0.75rem;
      margin: 10px 0;
    }

    .test-divider {
      border: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      margin: 15px 0;
    }

    .success { color: #00ffaa; }
    .error { color: #ff4444; }
    .loading { color: #aaa; font-style: italic; }

    .success-box {
      background: rgba(0, 255, 170, 0.1);
      border: 1px solid rgba(0, 255, 170, 0.2);
      padding: 12px;
      border-radius: 8px;
      text-align: center;
    }

    .btn-checkout {
      display: block;
      width: 100%;
      margin-top: 10px;
      background: #00ffaa;
      color: #000;
      border: none;
      padding: 8px;
      border-radius: 4px;
      font-weight: bold;
      cursor: pointer;
    }

    .pix-result {
      width: 100%;
      padding: 18px;
      border-radius: 24px;
      border: 1px solid rgba(185, 214, 49, 0.58);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
        rgba(18, 21, 24, 0.86);
      color: #fff;
    }

    .pix-result[hidden] {
      display: none;
    }

    .pix-result-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 14px;
    }

    .pix-result-head h2 {
      margin: 8px 0 0;
      font-size: 20px;
      line-height: 1.1;
    }

    .pix-close {
      width: 34px;
      height: 34px;
      display: inline-grid;
      place-items: center;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.86);
      font-size: 20px;
      cursor: pointer;
    }

    .pix-qr {
      width: min(100%, 260px);
      aspect-ratio: 1;
      display: block;
      margin: 0 auto 14px;
      border-radius: 12px;
      background: #fff;
      object-fit: contain;
      padding: 8px;
    }

    .pix-label {
      display: block;
      margin: 0 0 8px;
      color: rgba(255, 255, 255, 0.76);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .pix-code {
      width: 100%;
      height: 48px;
      margin: 0 0 10px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(0, 0, 0, 0.36);
      color: rgba(255, 255, 255, 0.7);
      padding: 0 16px;
      font: 13px/48px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      outline: none;
      transition: all 0.2s ease;
      cursor: text;
    }

    .pix-code:focus {
      border-color: rgba(185, 214, 49, 0.58);
      color: rgba(255, 255, 255, 1);
      background: rgba(0, 0, 0, 0.5);
    }

    .pix-meta {
      margin: 10px 0 0;
      color: rgba(255, 255, 255, 0.66);
      font-size: 12px;
      line-height: 1.4;
    }



    .btn-token {
      width: 100%;
      min-height: 50px;
      margin-top: 2px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(255, 255, 255, 0.18);
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
    }

    .price {
      flex: 0 0 auto;
      color: #fff;
      font-size: 31px;
      line-height: 1;
      font-weight: 820;
      text-align: right;
      white-space: nowrap;
    }

    .price::first-line {
      color: #fff;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      border-radius: 999px;
      padding: 3px 10px;
      background: rgba(255, 255, 255, 0.14);
      color: rgba(255, 255, 255, 0.86);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .badge.best-value {
      background: rgba(255, 255, 255, 0.9);
      color: #000;
    }

    .badge.pro-badge {
      background: var(--accent);
      color: #000;
    }

    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 14px;
      display: grid;
      gap: 8px;
    }

    .features li {
      position: relative;
      padding-left: 22px;
      color: rgba(255, 255, 255, 0.76);
      font-size: 14px;
      line-height: 1.38;
    }

    .features li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.5em;
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--accent);
    }

    @media (max-width: 480px) {
      .upgrade-container {
        padding-right: 14px;
        padding-left: 14px;
      }

      .plan-card {
        border-radius: 24px;
        padding: 17px;
      }

      .plan-head h2 {
        font-size: 20px;
      }

      .price {
        font-size: 29px;
      }
    }
  </style>

  <script is:inline define:vars={{ 
    PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL,
  }}>
    const productionApiUrl = 'https://api.noxai.chat';
    const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
    const configuredApiUrl = String(PUBLIC_API_URL || '').trim().replace(/\/$/, '');
    const configuredApiIsLocal = /^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i.test(configuredApiUrl);
    const apiUrl = configuredApiUrl && (isLocalhost || !configuredApiIsLocal)
      ? configuredApiUrl
      : (isLocalhost ? 'http://localhost:3001' : productionApiUrl);
    const API_URL = apiUrl;
    const tokenStorageKey = 'nox_token';
    const tokenCookieMaxAge = 7 * 24 * 60 * 60;

    function getCookie(name) {
      const value = `; ${document.cookie}`;
      const parts = value.split(`; ${name}=`);
      if (parts.length === 2) return parts.pop().split(';').shift();
      return null;
    }

    function persistAuthToken(token) {
      const secure = window.location.protocol === 'https:' ? '; Secure' : '';
      localStorage.setItem(tokenStorageKey, token);
      document.cookie = `${tokenStorageKey}=${token}; path=/; max-age=${tokenCookieMaxAge}; SameSite=Lax${secure}`;
    }

    function decodeSessionToken(token) {
      try {
        const payload = token.split('.')[1];
        if (!payload) return null;
        const normalized = payload.replace(/-/g, '+').replace(/_/g, '/');
        const padded = normalized.padEnd(Math.ceil(normalized.length / 4) * 4, '=');
        return JSON.parse(atob(padded));
      } catch {
        return null;
      }
    }

    function isGuestToken(token) {
      const session = decodeSessionToken(token);
      return Boolean(
        session?.guest ||
        String(session?.id || '').startsWith('guest_') ||
        session?.tier === 'guest'
      );
    }

    function getAuthToken() {
      const cookieToken = getCookie(tokenStorageKey);
      const storedToken = localStorage.getItem(tokenStorageKey);

      if (cookieToken && storedToken && isGuestToken(cookieToken) && !isGuestToken(storedToken)) {
        persistAuthToken(storedToken);
        return storedToken;
      }

      if (cookieToken) {
        localStorage.setItem(tokenStorageKey, cookieToken);
        return cookieToken;
      }

      return storedToken;
    }

    async function readJsonResponse(response) {
      try {
        return await response.json();
      } catch {
        return {};
      }
    }

    const CheckoutManager = {
      KEY: 'nox_pending_cart',
      TTL_MS: 30 * 60 * 1000,
      save(pkgId, pixData) {
        try {
          const payload = JSON.stringify({ pkgId, pixData, savedAt: Date.now() });
          localStorage.setItem(this.KEY, payload);
        } catch (error) {
          console.warn('[System Storage] Falha ao persistir estado do carrinho:', error);
        }
      },
      clear() {
        try { localStorage.removeItem(this.KEY); } catch (error) { console.warn('[System Storage] Falha ao limpar carrinho:', error); }
      },
      restore() {
        try {
          const raw = localStorage.getItem(this.KEY);
          if (!raw) return null;
          const cart = JSON.parse(raw);
          const isExpired = (Date.now() - cart.savedAt) > this.TTL_MS;
          if (!cart.pixData || isExpired) {
            this.clear();
            return null;
          }
          return cart;
        } catch (error) {
          console.error('[System Storage] Corrupção de dados no carrinho. Resetando.', error);
          this.clear();
          return null;
        }
      }
    };

    const PaymentMonitor = {
      intervalId: null,
      attempts: 0,
      MAX_ATTEMPTS: 120, // 10 minutos
      POLL_INTERVAL_MS: 5000,
      abortController: null,
      start(baselineData, onSuccess) {
        this.stop();
        this.attempts = 0;
        console.info('[System Monitor] Iniciando rastreio de liquidação de PIX.');
        this.intervalId = setInterval(() => {
          this.checkStatus(baselineData, onSuccess);
        }, this.POLL_INTERVAL_MS);
      },
      async checkStatus(baselineData, onSuccess) {
        this.attempts++;
        if (this.attempts > this.MAX_ATTEMPTS) {
          console.warn('[System Monitor] Timeout atingido. Encerrando polling.');
          this.stop();
          return;
        }
        if (this.abortController) this.abortController.abort();
        this.abortController = new AbortController();
        try {
          // Checa diretamente no backend se a transação do FlowPay foi liquidada
          const token = getAuthToken();
          const response = await fetch(`${API_URL}/api/transactions/${baselineData.txId}/status`, {
            headers: { 'Authorization': `Bearer ${token}` },
            signal: this.abortController.signal
          });
          const currentData = await readJsonResponse(response);
          if (currentData.status === 'PAID') {
            console.info('[System Monitor] Pagamento confirmado on-chain/backend.');
            this.stop();
            onSuccess(currentData);
          }
        } catch (error) {
          if (error.name === 'AbortError') return;
          console.error('[System Network] Falha no ciclo de polling:', error);
        }
      },
      stop() {
        if (this.intervalId) { clearInterval(this.intervalId); this.intervalId = null; }
        if (this.abortController) { this.abortController.abort(); this.abortController = null; }
      }
    };

    function triggerPaymentSuccess() {
      const panel = document.getElementById('pix-result');
      if (panel) {
        panel.innerHTML = '<div class="success-state" style="padding: 2rem; text-align: center; color: var(--color-brand); font-weight: bold;">Pagamento Confirmado! Seus tokens já estão disponíveis. Redirecionando...</div>';
        setTimeout(() => { window.location.href = '/'; }, 3000);
      }
      CheckoutManager.clear();
    }

    function initCartRecovery() {
      const pendingCart = CheckoutManager.restore();
      if (!pendingCart) return;
      console.info('[System Cart] Reidratando sessão de checkout pendente.');
      showPixCharge(pendingCart.pixData);
    }

    function normalizePixData(data) {
      const pixData = data?.pixData || data?.pix_data || {};
      return {
        qrCode: pixData.qrCode || pixData.qr_code || null,
        brCode: pixData.brCode || pixData.br_code || null,
        correlationId: pixData.correlationId || pixData.correlation_id || data?.chargeId || null,
        value: pixData.value ?? null,
        expiresAt: pixData.expiresAt || pixData.expires_at || null,
        status: pixData.status || null,
      };
    }

    function showPixCharge(data) {
      const pixData = normalizePixData(data);
      if (!pixData.brCode && !pixData.qrCode) return false;

      const panel = document.getElementById('pix-result');
      const qr = document.getElementById('pix-qr');
      const code = document.getElementById('pix-code');
      const meta = document.getElementById('pix-meta');

      if (!panel || !qr || !code || !meta) return false;

      if (pixData.qrCode) {
        qr.src = pixData.qrCode;
        qr.hidden = false;
      } else {
        qr.removeAttribute('src');
        qr.hidden = true;
      }

      code.value = pixData.brCode || '';

      const metaParts = [
        pixData.value ? `R$ ${Number(pixData.value).toFixed(2)}` : null,
        pixData.status === 'ACTIVE' ? '· Aguardando pagamento' : null,
      ].filter(Boolean);
      meta.textContent = metaParts.join(' ');

      panel.hidden = false;
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (pixData.correlationId) {
        PaymentMonitor.start({ txId: pixData.correlationId }, triggerPaymentSuccess);
      }

      return true;
    }

    function handleBillingResponse(data) {
      if (data.checkoutUrl) {
        window.location.href = data.checkoutUrl;
        return;
      }

      if (showPixCharge(data)) {
        const pixData = normalizePixData(data);
        CheckoutManager.save(data._pkgId || null, pixData);
        return;
      }

      alert('Ops! Tivemos um imprevisto ao gerar seu Pix. Por favor, tente novamente em alguns instantes.');
    }

    window.closePixResult = function() {
      const panel = document.getElementById('pix-result');
      if (panel) panel.hidden = true;
      CheckoutManager.clear();
      PaymentMonitor.stop();
    }

    window.copyPixCode = async function(btn) {
      const code = document.getElementById('pix-code');
      if (!code || !code.value) return;

      const selectPixCode = () => {
        code.focus();
        code.select();
        code.setSelectionRange(0, code.value.length);
      };

      if (!navigator.clipboard?.writeText) {
        selectPixCode();
        const cmd = ['exec', 'Command'].join('');
        document[cmd]('copy');
      } else {
        try {
          await navigator.clipboard.writeText(code.value);
        } catch {
          selectPixCode();
          const cmd = ['exec', 'Command'].join('');
          document[cmd]('copy');
        }
      }

      if (btn) {
        const originalText = btn.dataset.originalText || btn.innerText;
        btn.dataset.originalText = originalText;
        
        btn.innerText = '✓ COPIADO!';
        btn.style.color = '#000';
        btn.style.background = '#b9d631';
        btn.style.borderColor = '#b9d631';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.color = '';
          btn.style.background = '';
          btn.style.borderColor = '';
        }, 2500);
      }
    }

    window.checkFlowHealth = async function() {
      const token = getAuthToken();
      const statusEl = document.getElementById('health-status');
      statusEl.innerHTML = '<span class="loading">Probing API...</span>';
      
      try {
        const res = await fetch(`${API_URL}/api/flowpay/health`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await readJsonResponse(res);
        statusEl.innerHTML = data.status === 'online' 
          ? `<span class="success">FlowPay Online (${data.statusCode})</span>`
          : `<span class="error">FlowPay Offline</span>`;
      } catch (err) {
        statusEl.innerHTML = `<span class="error">Error: ${err.message}</span>`;
      }
    }

    window.testFlowCharge = async function() {
      const token = getAuthToken();
      const resultEl = document.getElementById('test-result');
      resultEl.innerHTML = '<span class="loading">Creating sandbox charge...</span>';
      
      try {
        const response = await fetch(`${API_URL}/api/flowpay/test-charge`, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}` 
          }
        });

        const data = await readJsonResponse(response);
        let errorMessage = 'Erro no servidor. Tente novamente mais tarde.';
        if (data.details || data.error) {
          errorMessage = data.details || data.error;
        } else if (!Object.keys(data).length) {
          errorMessage = `Erro ${response.status}: ${response.statusText}`;
        }

        if (!response.ok) {
          resultEl.innerHTML = `<div class="error-box">${errorMessage}</div>`;
          return;
        }

        if (data.success) {
          resultEl.innerHTML = `<div class="success-box"><p>Test charge criada</p><small>ID: ${data.chargeId || '-'}</small></div>`;
          if (data.checkoutUrl) {
            const box = resultEl.querySelector('.success-box');
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn-checkout';
            button.textContent = 'Abrir checkout de teste';
            button.addEventListener('click', () => window.open(data.checkoutUrl, '_blank', 'noopener'));
            box?.appendChild(button);
          } else {
            showPixCharge(data);
          }
        } else {
          resultEl.innerHTML = `<div class="error-box">${data.error || 'FlowPay test charge failed'}</div>`;
        }
      } catch (err) {
        resultEl.innerHTML = `<div class="error-box">${err.message}</div>`;
      }
    }

    async function createPurchase(endpoint, body, pkgId = null) {
      const token = getAuthToken();
      if (!token) return window.location.href = '/login';

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 30000);

      try {
        const response = await fetch(`${apiUrl}${endpoint}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(body),
          signal: controller.signal
        });

        clearTimeout(timeoutId);
        const data = await readJsonResponse(response);

        if (!response.ok) {
          // Mapeamento de erros técnicos para mensagens elegantes
          const isAuthError = data.error?.toLowerCase().includes('autenticação') || response.status === 401;
          const userFriendlyMsg = isAuthError 
            ? 'Estamos ajustando nosso sistema de pagamentos. Por favor, tente novamente em breve.'
            : 'Não foi possível iniciar o pagamento agora. Tente novamente em instantes.';
            
          alert(`NØX: ${userFriendlyMsg}`);
          return;
        }

        handleBillingResponse({ ...data, _pkgId: pkgId });
      } catch (error) {
        clearTimeout(timeoutId);
        const isTimeout = error.name === 'AbortError';
        alert(isTimeout ? 'O servidor demorou muito para responder. Tente novamente.' : 'Erro de conexão. Verifique sua internet.');
      }
    }

    window.buyTokens = async function(packageType, btn) {
      if (btn?.disabled) return;
      if (btn) {
        btn.disabled = true;
        btn.dataset.text = btn.innerText;
        btn.innerText = 'GERANDO PIX...';
      }
      await createPurchase('/api/tokens/purchase', { package: packageType }, packageType);
      if (btn) {
        btn.disabled = false;
        btn.innerText = btn.dataset.text;
      }
    }

    window.buyProduct = function(productId) {
      return createPurchase('/api/products/purchase', { productId }, productId);
    }

    document.addEventListener('DOMContentLoaded', initCartRecovery);
  </script>
</Layout>
