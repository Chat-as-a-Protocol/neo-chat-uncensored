---
import Layout from '../layouts/Layout.astro';
import plans from '../../shared/plans.json';

const token = Astro.cookies.get('nox_token')?.value;

if (!token) {
  return Astro.redirect('/login');
}

const packages = Object.values(plans.packages);
const products = Object.values(plans.products || {});
const guestTier = plans.tiers.guest;
---

<Layout title="NØX - Upgrade">
  <div class="upgrade-container">
    <main class="upgrade-shell">
      <header class="upgrade-header">
        <a href="/" class="back-link" aria-label="Voltar ao terminal">←</a>
        <img src="/nox_vert.webp" alt="NØX" class="nox-logo" />
        <h1>Upgrade</h1>
      </header>

      <section class="plan-card is-current" aria-label="Plano atual">
        <div class="plan-head">
          <div>
            <span class="badge guest-badge">FREE</span>
            <h2>{guestTier.name}</h2>
            <p>Degustação</p>
          </div>
          <strong class="price">R$ 0</strong>
        </div>

        <ul class="features">
          {guestTier.benefits.map((benefit) => (
            <li>{benefit}</li>
          ))}
        </ul>
      </section>
      
      <section class="plans-stack" aria-label="Pacotes de tokens">
        {packages.map((pkg) => (
          <article class={`plan-card ${pkg.id === '10k' ? 'is-pro' : ''} ${pkg.id === '5k' ? 'is-popular' : ''}`}>
            <div class="plan-head">
              <div>
                {pkg.id === '5k' && <span class="badge best-value">Melhor valor</span>}
                {pkg.id === '10k' && <span class="badge pro-badge">Pro</span>}
                <h2>{pkg.name}</h2>
                <p>{pkg.tokens.toLocaleString()} tokens</p>
              </div>
              <strong class="price">R$ {pkg.price}</strong>
            </div>
            
            <ul class="features">
              {pkg.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>

            <button onclick={`buyTokens('${pkg.id}')`} class="btn-token">
              {pkg.id === '10k' ? 'ASCENDER' : 'ATIVAR'}
            </button>
          </article>
        ))}
      </section>

      {products.length > 0 && (
        <section class="plans-stack products-stack" aria-label="Produtos P.R.O">
          {products.map((product) => (
            <article class="plan-card is-product">
              <div class="plan-head">
                <div>
                  <span class="badge pro-badge">P.R.O</span>
                  <h2>{product.name}</h2>
                  <p>{product.category}</p>
                </div>
                <strong class="price">R$ {product.price}</strong>
              </div>

              <ul class="features">
                {product.benefits.map((benefit) => (
                  <li>{benefit}</li>
                ))}
              </ul>

              <button onclick={`buyProduct('${product.id}')`} class="btn-token">
                ATIVAR P.R.O
              </button>
            </article>
          ))}
        </section>
      )}

      {import.meta.env.PUBLIC_ENABLE_FLOWPAY_DIAGNOSTICS === 'true' && (
        <div class="test-panel" id="flowpay-test">
          <div class="test-header">
            <span class="test-title">Sovereign Payment Diagnostics</span>
            <button onclick="checkFlowHealth()" class="btn-check">Check API</button>
          </div>
          <div id="health-status" class="health-status"></div>
          <hr class="test-divider" />
          <button onclick="testFlowCharge()" class="btn-test">Simulate Test Charge (R$ 1.00)</button>
          <div id="test-result" class="test-result"></div>
        </div>
      )}
    </main>
  </div>

  <style>
    .upgrade-container {
      min-height: 100svh;
      position: relative;
      isolation: isolate;
      padding: max(18px, env(safe-area-inset-top)) 16px max(22px, env(safe-area-inset-bottom));
      background: url('/bg_claro.webp') center/cover no-repeat;
      background-color: #000;
      font-family: 'Space Grotesk', sans-serif;
      overflow-y: auto;
    }

    .upgrade-container::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(180deg, rgba(6, 7, 10, 0.36), rgba(6, 7, 10, 0.78)),
        rgba(220, 226, 220, 0.2);
      backdrop-filter: blur(3px) saturate(0.74);
      -webkit-backdrop-filter: blur(3px) saturate(0.74);
    }

    .upgrade-shell {
      width: 100%;
      max-width: 480px;
      min-height: 100%;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 0 2px 12px;
    }

    .upgrade-header {
      position: sticky;
      top: 0;
      z-index: 10;
      display: grid;
      grid-template-columns: 44px 1fr 44px;
      align-items: center;
      gap: 10px;
      padding: 8px 0 12px;
      background: linear-gradient(180deg, rgba(220, 226, 220, 0.72), rgba(220, 226, 220, 0));
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .back-link {
      width: 38px;
      height: 38px;
      display: inline-grid;
      place-items: center;
      border-radius: 999px;
      color: rgba(255, 255, 255, 0.88);
      background: rgba(13, 15, 18, 0.48);
      border: 1px solid rgba(255, 255, 255, 0.16);
      font-size: 22px;
      line-height: 1;
    }

    .nox-logo {
      justify-self: center;
      width: 116px;
      height: auto;
      object-fit: contain;
      filter: drop-shadow(0 10px 24px rgba(0, 0, 0, 0.34));
    }

    .upgrade-header h1 {
      grid-column: 1 / -1;
      margin: -4px 0 0;
      color: rgba(255, 255, 255, 0.94);
      font-size: 24px;
      font-weight: 700;
      text-align: center;
      text-shadow: 0 2px 22px rgba(0, 0, 0, 0.55);
    }

    .plans-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .products-stack {
      padding-top: 2px;
    }

    .plan-card {
      width: 100%;
      padding: 18px;
      border-radius: 26px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.07)),
        rgba(18, 21, 24, 0.72);
      box-shadow:
        0 18px 50px rgba(0, 0, 0, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.26);
      backdrop-filter: blur(22px) saturate(1.16);
      -webkit-backdrop-filter: blur(22px) saturate(1.16);
      color: #fff;
    }

    .plan-card.is-current {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.08)),
        rgba(37, 41, 43, 0.68);
    }

    .plan-card.is-popular,
    .plan-card.is-pro,
    .plan-card.is-product {
      border-color: rgba(185, 214, 49, 0.58);
    }

    .plan-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 14px;
    }

    .plan-head h2 {
      margin: 8px 0 3px;
      color: rgba(255, 255, 255, 0.95);
      font-size: 21px;
      line-height: 1.08;
      font-weight: 760;
      letter-spacing: 0;
    }

    .plan-head p {
      margin: 0;
      color: var(--accent);
      font-size: 14px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .usage-hint {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      padding: 10px;
      margin: 10px 0;
      font-size: 0.75rem;
      border-left: 3px solid var(--accent);
      text-align: left;
    }

    .usage-hint p {
      margin: 0;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.8);
    }

    .tokens-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    /* Diagnostics Panel Styles */
    .test-panel {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 20px;
      margin-top: 40px;
      font-family: 'Space Grotesk', sans-serif;
    }

    .test-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .test-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.5);
    }

    .btn-check, .btn-test {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: white;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-test {
      width: 100%;
      background: rgba(var(--accent-rgb), 0.1);
      border-color: var(--accent);
      color: var(--accent);
      font-weight: bold;
    }

    .btn-check:hover, .btn-test:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .health-status, .test-result {
      font-family: monospace;
      font-size: 0.75rem;
      margin: 10px 0;
    }

    .test-divider {
      border: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      margin: 15px 0;
    }

    .success { color: #00ffaa; }
    .error { color: #ff4444; }
    .loading { color: #aaa; font-style: italic; }

    .success-box {
      background: rgba(0, 255, 170, 0.1);
      border: 1px solid rgba(0, 255, 170, 0.2);
      padding: 12px;
      border-radius: 8px;
      text-align: center;
    }

    .btn-checkout {
      display: block;
      width: 100%;
      margin-top: 10px;
      background: #00ffaa;
      color: #000;
      border: none;
      padding: 8px;
      border-radius: 4px;
      font-weight: bold;
      cursor: pointer;
    }



    .btn-token {
      width: 100%;
      min-height: 50px;
      margin-top: 2px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(255, 255, 255, 0.18);
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-token:hover {
      background: var(--accent);
      color: black;
      border-color: var(--accent);
    }

    .price {
      flex: 0 0 auto;
      color: #fff;
      font-size: 31px;
      line-height: 1;
      font-weight: 820;
      text-align: right;
      white-space: nowrap;
    }

    .price::first-line {
      color: #fff;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      border-radius: 999px;
      padding: 3px 10px;
      background: rgba(255, 255, 255, 0.14);
      color: rgba(255, 255, 255, 0.86);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .badge.best-value {
      background: rgba(255, 255, 255, 0.9);
      color: #000;
    }

    .badge.guest-badge {
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.82);
    }

    .badge.pro-badge {
      background: var(--accent);
      color: #000;
    }

    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 14px;
      display: grid;
      gap: 8px;
    }

    .features li {
      position: relative;
      padding-left: 22px;
      color: rgba(255, 255, 255, 0.76);
      font-size: 14px;
      line-height: 1.38;
    }

    .features li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.5em;
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 12px rgba(185, 214, 49, 0.48);
    }

    @media (max-width: 480px) {
      .upgrade-container {
        padding-right: 14px;
        padding-left: 14px;
      }

      .plan-card {
        border-radius: 24px;
        padding: 17px;
      }

      .plan-head h2 {
        font-size: 20px;
      }

      .price {
        font-size: 29px;
      }
    }

    @media (min-width: 768px) {
      .upgrade-container {
        padding-top: 22px;
      }
    }
  </style>

  <script is:inline define:vars={{ 
    PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL,
  }}>
    const productionApiUrl = 'https://backend-vit.up.railway.app';
    const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
    const configuredApiUrl = String(PUBLIC_API_URL || '').trim().replace(/\/$/, '');
    const configuredApiIsLocal = /^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i.test(configuredApiUrl);
    const apiUrl = configuredApiUrl && (isLocalhost || !configuredApiIsLocal)
      ? configuredApiUrl
      : (isLocalhost ? 'http://localhost:3001' : productionApiUrl);
    const API_URL = apiUrl;
    const tokenStorageKey = 'nox_token';

    function getAuthToken() {
      return localStorage.getItem(tokenStorageKey);
    }

    window.checkFlowHealth = async function() {
      const token = getAuthToken();
      const statusEl = document.getElementById('health-status');
      statusEl.innerHTML = '<span class="loading">Probing API...</span>';
      
      try {
        const res = await fetch(`${API_URL}/api/flowpay/health`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        statusEl.innerHTML = data.status === 'online' 
          ? `<span class="success">● FlowPay Online (${data.statusCode})</span>`
          : `<span class="error">● FlowPay Offline</span>`;
      } catch (err) {
        statusEl.innerHTML = `<span class="error">● Error: ${err.message}</span>`;
      }
    }

    window.testFlowCharge = async function() {
      const token = getAuthToken();
      const resultEl = document.getElementById('test-result');
      resultEl.innerHTML = '<span class="loading">Creating sandbox charge...</span>';
      
      try {
        const res = await fetch(`${API_URL}/api/flowpay/test-charge`, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}` 
          }
        });
        const data = await res.json();
        if (data.success) {
          resultEl.innerHTML = `
            <div class="success-box">
              <p>✅ Test Charge Created</p>
              <small>ID: ${data.chargeId}</small>
              <button onclick="window.open('${data.checkoutUrl}', '_blank')" class="btn-checkout">Open Test Checkout</button>
            </div>
          `;
        } else {
          resultEl.innerHTML = `<div class="error-box">❌ ${data.error}</div>`;
        }
      } catch (err) {
        resultEl.innerHTML = `<div class="error-box">❌ ${err.message}</div>`;
      }
    }

    window.buyTokens = async function(packageType) {
      const token = getAuthToken();
      if (!token) return window.location.href = '/login';
      
      try {
        const response = await fetch(`${apiUrl}/api/tokens/purchase`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ package: packageType })
        });
        
        const data = await response.json();
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Connection error. Please try again.');
      }
    }

    window.buyProduct = async function(productId) {
      const token = getAuthToken();
      if (!token) return window.location.href = '/login';

      try {
        const response = await fetch(`${apiUrl}/api/products/purchase`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ productId })
        });

        const data = await response.json();
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Connection error. Please try again.');
      }
    }
  </script>
</Layout>
