---
import AstroChatInterface from '../components/AstroChatInterface.astro';
import Layout from '../layouts/Layout.astro';
import SceneBackground from '../components/SceneBackground.astro';

Astro.response.headers.set(
  'Link',
  '</.well-known/api-catalog>; rel="describedby", </docs/api>; rel="service-doc"'
);

// A "trava" agora é gerenciada dentro do componente de Chat para permitir a amostra de 3 mensagens.
// O redirecionamento só acontece se o usuário tentar acessar páginas Pro ou se o componente decidir.
---

<Layout title="NØX AI">
  <main class="scene-shell">
    <SceneBackground animateLogo={false} />

    <div class="intro-splash" aria-hidden="true">
      <img src="/neoai.png" alt="" />
    </div>

    <AstroChatInterface />

    <footer class="scene-footer">
      <div class="footer-legal">
        <a href="/privacy" data-label="PRIVACY">PRIVACY</a>
        <span class="dot">·</span>
        <a href="/terms" data-label="TERMS">TERMS</a>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .scene-shell {
    position: relative;
    isolation: isolate;
    height: 100%;
    min-height: 100%;
    padding: clamp(14px, 2.2vw, 28px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    background: #000000;
  }

  /* Esconde footer quando o chat está ativo/focado no mobile */
  :global(body.chat-input-focused) .scene-footer,
  :global(body.keyboard-open) .scene-footer {
    display: none;
  }

  .scene-footer {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    flex: 0 0 auto;
    text-align: center;
    color: rgba(236, 236, 236, 0.3);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.35;
    padding-bottom: clamp(12px, 1.8vw, 22px);
  }

  .scene-footer a {
    position: relative;
    display: inline-block;
    opacity: 0.78;
    transition: opacity 0.2s, color 0.2s;
  }

  .scene-footer a:hover,
  .scene-footer a:focus-visible {
    opacity: 1;
    color: var(--accent);
    outline: none;
  }

  /* Efeito Glitch Ambiente Apenas nos Links Principais */
  .footer-links a::before,
  .footer-links a::after {
    content: attr(data-label);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .footer-links a::before {
      left: 1px;
      text-shadow: -1px 0 rgba(255, 255, 255, 0.4);
      animation: ambient-glitch 30s cubic-bezier(.25, .46, .45, .94) infinite;
      animation-delay: -27.5s;
    }

    .footer-links a::after {
      left: -1px;
      text-shadow: -1px 0 var(--accent);
      animation: ambient-glitch-2 30s cubic-bezier(.25, .46, .45, .94) infinite;
      animation-delay: -27.5s;
    }
  }

  @keyframes ambient-glitch {
    0%, 99%, 100% { opacity: 0; clip-path: inset(0 0 0 0); }
    99.2% { opacity: 0.8; clip-path: inset(10% 0 80% 0); }
    99.4% { opacity: 0.8; clip-path: inset(80% 0 10% 0); }
    99.6% { opacity: 0.8; clip-path: inset(40% 0 40% 0); }
    99.8% { opacity: 0.8; clip-path: inset(10% 0 60% 0); }
    99.9% { opacity: 0.8; clip-path: inset(50% 0 30% 0); }
  }

  @keyframes ambient-glitch-2 {
    0%, 99%, 100% { opacity: 0; clip-path: inset(0 0 0 0); }
    99.2% { opacity: 0.8; clip-path: inset(20% 0 60% 0); }
    99.4% { opacity: 0.8; clip-path: inset(60% 0 20% 0); }
    99.6% { opacity: 0.8; clip-path: inset(30% 0 50% 0); }
    99.8% { opacity: 0.8; clip-path: inset(80% 0 10% 0); }
    99.9% { opacity: 0.8; clip-path: inset(10% 0 80% 0); }
  }

  .scene-footer .telegram-link {
    display: inline-flex;
    width: 1.1em;
    height: 1.1em;
    align-items: center;
    justify-content: center;
    vertical-align: -0.14em;
  }

  .scene-footer .telegram-link svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .scene-footer .dot {
    display: inline-block;
    margin: 0 10px;
    opacity: 0.42;
  }

  .footer-legal {
    margin-top: 8px;
    opacity: 0.6;
  }

  .intro-splash {
    position: fixed;
    inset: 0;
    z-index: 10000; /* Acima de tudo */
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background: #000;
    animation: intro-out 1900ms ease forwards;
  }

  .intro-splash img {
    width: 80vw;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 36px 70px rgba(0, 0, 0, 0.72));
    animation: logo-pulse 1500ms ease forwards;
  }

  :global(.chat-ui-shell),
  .scene-footer {
    opacity: 0;
    transform: translateY(14px);
    animation: chat-in 700ms ease forwards;
    animation-delay: 1450ms;
  }

  @keyframes logo-pulse {
    0% { opacity: 0; transform: scale(1.04); }
    15% { opacity: 1; transform: scale(1); }
    85% { opacity: 1; transform: scale(0.995); }
    100% { opacity: 0; transform: scale(0.98); }
  }

  @keyframes intro-out {
    0%, 72% { opacity: 1; }
    100% { opacity: 0; visibility: hidden; }
  }

  @keyframes chat-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .scene-shell {
      padding-top: calc(env(safe-area-inset-top) + 8px);
      padding-right: max(8px, env(safe-area-inset-right));
      padding-bottom: calc(env(safe-area-inset-bottom) + 10px);
      padding-left: max(8px, env(safe-area-inset-left));
    }

    .scene-footer {
      font-size: 14px;
      padding-bottom: calc(env(safe-area-inset-bottom) + 4px);
    }

    .scene-footer .dot {
      margin: 0 10px;
    }
  }
</style>
