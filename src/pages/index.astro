---
import AstroChatInterface from '../components/AstroChatInterface.astro';
import Layout from '../layouts/Layout.astro';
import SceneBackground from '../components/SceneBackground.astro';

// A "trava" agora é gerenciada dentro do componente de Chat para permitir a amostra de 3 mensagens.
// O redirecionamento só acontece se o usuário tentar acessar páginas Pro ou se o componente decidir.
---

<Layout title="NØX Uncensored Chat">
  <main class="scene-shell">
    <SceneBackground animateLogo={false} />

    <div class="intro-splash" aria-hidden="true">
      <img src="/neoai.png" alt="" />
    </div>

    <AstroChatInterface />

    <footer class="scene-footer">
      <div class="footer-links">
        <a href="/upgrade">Upgrade</a>
        <span class="dot">·</span>
        <a href="/precos">Preços</a>
        <span class="dot">·</span>
        <a href="/conta">Conta</a>
      </div>
      <div class="footer-legal mt-2">
        <a href="/privacy-policy" aria-label="Política de Privacidade">Privacy</a>
        <span class="dot">·</span>
        <a href="/terms-and-conditions" aria-label="Termos e Condições">Terms</a>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .scene-shell {
    position: relative;
    isolation: isolate;
    height: 100dvh;
    padding: clamp(14px, 2.2vw, 28px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    background: #000000;
  }

  .scene-footer {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    flex: 0 0 auto;
    text-align: center;
    color: rgba(236, 236, 236, 0.44);
    font-size: clamp(14px, 1.9vw, 22px);
    line-height: 1.35;
    padding-bottom: clamp(12px, 1.8vw, 22px);
  }

  .scene-footer a {
    opacity: 0.78;
  }

  .scene-footer .dot {
    display: inline-block;
    margin: 0 14px;
    opacity: 0.42;
  }

  .intro-splash {
    position: fixed;
    inset: 0;
    z-index: 10000; /* Acima de tudo */
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background: #000;
    animation: intro-out 1900ms ease forwards;
  }

  .intro-splash img {
    width: 80vw;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 36px 70px rgba(0, 0, 0, 0.72));
    animation: logo-pulse 1500ms ease forwards;
  }

  :global(.chat-ui-shell),
  .scene-footer {
    opacity: 0;
    transform: translateY(14px);
    animation: chat-in 700ms ease forwards;
    animation-delay: 1450ms;
  }

  @keyframes logo-pulse {
    0% { opacity: 0; transform: scale(1.04); }
    15% { opacity: 1; transform: scale(1); }
    85% { opacity: 1; transform: scale(0.995); }
    100% { opacity: 0; transform: scale(0.98); }
  }

  @keyframes intro-out {
    0%, 72% { opacity: 1; }
    100% { opacity: 0; visibility: hidden; }
  }

  @keyframes chat-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .scene-shell {
      padding-top: calc(env(safe-area-inset-top) + 8px);
      padding-right: max(8px, env(safe-area-inset-right));
      padding-bottom: calc(env(safe-area-inset-bottom) + 10px);
      padding-left: max(8px, env(safe-area-inset-left));
    }

    .scene-footer {
      font-size: 14px;
      padding-bottom: calc(env(safe-area-inset-bottom) + 4px);
    }

    .scene-footer .dot {
      margin: 0 10px;
    }
  }
</style>
