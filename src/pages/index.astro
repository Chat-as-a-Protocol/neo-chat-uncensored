---
import AstroChatInterface from '../components/AstroChatInterface.astro';
import Layout from '../layouts/Layout.astro';
import SceneBackground from '../components/SceneBackground.astro';
const enableAuth = import.meta.env.ENABLE_AUTH_PAGES === 'true';

if (enableAuth) {
  const token = Astro.cookies.get('neo_token')?.value;
  if (!token) {
    return Astro.redirect('/login');
  }
}
---

<Layout title="NEØ Uncensored Chat">
  <main class="scene-shell">
    <SceneBackground />

    <div class="intro-splash" aria-hidden="true">
      <img src="/neoai.png" alt="" />
    </div>

    <AstroChatInterface />

    <footer class="scene-footer">
      <div class="footer-links">
        {enableAuth && (
          <>
            <a href="/login">Login</a>
            <span class="dot">•</span>
            <a href="/signup">Sign Up</a>
            <span class="dot">•</span>
            <a href="/upgrade">Upgrade</a>
          </>
        )}
      </div>
      <div class="footer-legal mt-2">
        <a href="/privacy-policy" aria-label="Política de Privacidade">Privacy Policy</a>
        <span class="dot">•</span>
        <a href="/terms-and-conditions" aria-label="Termos e Condições">Terms & Conditions</a>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .scene-shell {
    position: relative;
    isolation: isolate;
    height: 100dvh;
    padding: clamp(14px, 2.2vw, 28px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    background: #000000;
  }

  .scene-footer {
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    flex: 0 0 auto;
    text-align: center;
    color: rgba(236, 236, 236, 0.44);
    font-size: clamp(14px, 1.9vw, 22px);
    line-height: 1.35;
    padding-bottom: clamp(12px, 1.8vw, 22px);
  }

  .scene-footer a {
    opacity: 0.78;
  }

  .scene-footer .dot {
    display: inline-block;
    margin: 0 14px;
    opacity: 0.42;
  }

  .intro-splash {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: grid;
    place-items: center;
    pointer-events: none;
    background: #000;
    animation: intro-out 1900ms ease forwards;
  }

  .intro-splash img {
    width: min(120vw, 1100px);
    max-width: none;
    filter: drop-shadow(0 36px 70px rgba(0, 0, 0, 0.72));
    animation: logo-pulse 1500ms ease forwards;
  }

  :global(.chat-ui-shell),
  .scene-footer {
    opacity: 0;
    transform: translateY(14px);
    animation: chat-in 700ms ease forwards;
    animation-delay: 1450ms;
  }

  @keyframes logo-pulse {
    0% { opacity: 0; transform: scale(1.04); }
    24% { opacity: 1; transform: scale(1); }
    68% { opacity: 1; transform: scale(0.985); }
    100% { opacity: 0; transform: scale(0.97); }
  }

  @keyframes intro-out {
    0%, 72% { opacity: 1; }
    100% { opacity: 0; visibility: hidden; }
  }

  @keyframes chat-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .scene-shell {
      padding-top: calc(env(safe-area-inset-top) + 8px);
      padding-right: max(8px, env(safe-area-inset-right));
      padding-bottom: calc(env(safe-area-inset-bottom) + 10px);
      padding-left: max(8px, env(safe-area-inset-left));
    }

    .scene-footer {
      font-size: 14px;
      padding-bottom: calc(env(safe-area-inset-bottom) + 4px);
    }

    .scene-footer .dot {
      margin: 0 10px;
    }
  }
</style>
