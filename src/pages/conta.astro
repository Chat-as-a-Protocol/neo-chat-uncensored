---
import Layout from '../layouts/Layout.astro';

const token = Astro.cookies.get('nox_token')?.value;

if (!token) {
  return Astro.redirect('/login');
}
---

<Layout title="Conta · NØX.AI">
  <main class="account-shell">
    <section class="account-panel" aria-labelledby="account-title">
      <a href="/" class="back-link">← Terminal</a>

      <div class="account-heading">
        <span class="eyebrow">NØX.AI</span>
        <h1 id="account-title">Conta</h1>
      </div>

      <dl class="account-stats">
        <div>
          <dt>Plano</dt>
          <dd id="account-plan">--</dd>
        </div>
        <div>
          <dt>Uso hoje</dt>
          <dd id="account-usage">--/--</dd>
        </div>
        <div>
          <dt>Disponível</dt>
          <dd id="account-remaining">--</dd>
        </div>
        <div>
          <dt>Saldo NØX</dt>
          <dd id="account-balance">--</dd>
        </div>
      </dl>

      <p id="account-status" class="account-status">Carregando conta...</p>

      <div class="account-actions">
        <a href="/upgrade" class="primary-action">Upgrade</a>
        <button id="logout-button" type="button" class="secondary-action">Sair</button>
      </div>
    </section>
  </main>
</Layout>

<script>
  const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
  const apiUrl = import.meta.env.PUBLIC_API_URL || (isLocalhost ? 'http://localhost:3001' : 'https://backend-vit.up.railway.app');
  const accountPlanEl = document.getElementById('account-plan');
  const accountUsageEl = document.getElementById('account-usage');
  const accountRemainingEl = document.getElementById('account-remaining');
  const accountBalanceEl = document.getElementById('account-balance');
  const accountStatusEl = document.getElementById('account-status');
  const logoutButton = document.getElementById('logout-button');
  const tokenStorageKey = 'nox_token';

  function clearAuthToken() {
    localStorage.removeItem(tokenStorageKey);
    document.cookie = `${tokenStorageKey}=; path=/; max-age=0; SameSite=Lax`;
  }

  function getAuthToken() {
    return localStorage.getItem(tokenStorageKey);
  }

  function setStatus(message: string) {
    if (accountStatusEl) accountStatusEl.textContent = message;
  }

  function formatPlan(plan?: string, tier?: string) {
    const value = plan || tier || 'guest';
    if (value === 'guest') return 'Free';
    if (value === 'paid_basic') return 'Basic';
    if (value === 'paid_pro') return 'P.R.O';
    return value;
  }

  async function loadAccount() {
    const token = getAuthToken();
    if (!token) {
      window.location.href = '/login';
      return;
    }

    try {
      const usageResponse = await fetch(`${apiUrl}/api/usage`, {
        headers: { Authorization: `Bearer ${token}` },
      });

      if (usageResponse.status === 401) {
        clearAuthToken();
        window.location.href = '/login';
        return;
      }

      if (!usageResponse.ok) {
        setStatus('Não foi possível carregar a conta agora.');
        return;
      }

      const usage = await usageResponse.json();
      const remaining = Math.max(0, Number(usage.remaining || 0));

      if (accountPlanEl) accountPlanEl.textContent = formatPlan(usage.plan, usage.tier);
      if (accountUsageEl) accountUsageEl.textContent = `${usage.today}/${usage.limit}`;
      if (accountRemainingEl) accountRemainingEl.textContent = String(remaining);

      try {
        const ledgerResponse = await fetch(`${apiUrl}/api/ledger`, {
          headers: { Authorization: `Bearer ${token}` },
        });

        if (ledgerResponse.ok) {
          const ledger = await ledgerResponse.json();
          if (accountBalanceEl) accountBalanceEl.textContent = String(ledger.balance ?? 0);
        }
      } catch {
        if (accountBalanceEl) accountBalanceEl.textContent = '--';
      }

      setStatus('Conta sincronizada.');
    } catch {
      setStatus('Conexão indisponível. Tente novamente em instantes.');
    }
  }

  logoutButton?.addEventListener('click', () => {
    clearAuthToken();
    window.location.href = '/login';
  });

  loadAccount();
</script>

<style>
  .account-shell {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px;
    background: url('/bg_claro.webp') center/cover no-repeat;
    background-color: #000;
  }

  .account-panel {
    width: 100%;
    max-width: 430px;
    padding: 30px 24px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 22px;
    background: linear-gradient(145deg, rgba(20, 20, 25, 0.58), rgba(10, 10, 15, 0.3));
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.58);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 28px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.86rem;
  }

  .account-heading {
    margin-bottom: 24px;
  }

  .eyebrow {
    display: block;
    margin-bottom: 4px;
    color: var(--accent);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  h1 {
    color: #fff;
    font-size: 2.2rem;
  }

  .account-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: 0;
  }

  .account-stats div {
    min-width: 0;
    padding: 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.28);
  }

  dt {
    margin-bottom: 6px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.74rem;
  }

  dd {
    margin: 0;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.12rem;
    font-weight: 700;
  }

  .account-status {
    min-height: 20px;
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.86rem;
  }

  .account-actions {
    display: flex;
    gap: 10px;
    margin-top: 22px;
  }

  .primary-action,
  .secondary-action {
    flex: 1;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    cursor: pointer;
  }

  .primary-action {
    color: #101204;
    background: var(--accent);
  }

  .secondary-action {
    color: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 420px) {
    .account-stats {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 1.9rem;
    }
  }
</style>
