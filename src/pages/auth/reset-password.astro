---
import Layout from '../../layouts/Layout.astro';
import SceneBackground from '../../components/SceneBackground.astro';
import Card from '../../components/ui/Card.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';

if (import.meta.env.ENABLE_AUTH_PAGES === 'false') {
  return Astro.redirect('/');
}
---

<Layout title="Redefinir senha · NØX">
  <main class="scene-shell">
    <SceneBackground />

    <div class="content-container">
      <Card class="w-full max-w-[440px]" textured>
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold mb-2">Redefinir senha</h1>
          <p class="text-[var(--text-soft)]">Crie uma nova credencial de acesso.</p>
        </div>

        <form id="reset-form" class="flex flex-col gap-5">
          <Input
            type="password"
            name="newPassword"
            id="new-password"
            label="Nova senha"
            placeholder="••••••••"
            required
            autocomplete="new-password"
          />

          <Input
            type="password"
            name="confirmPassword"
            id="confirm-password"
            label="Confirmar senha"
            placeholder="••••••••"
            required
            autocomplete="new-password"
          />

          <p id="reset-status" class="text-sm text-[var(--text-soft)] text-center leading-relaxed">
            O link expira em 30 minutos.
          </p>

          <Button type="submit" class="mt-2" id="reset-submit">
            Atualizar senha
          </Button>
        </form>

        <div id="reset-success" class="hidden flex-col items-center gap-4 py-4 text-center">
          <div class="text-4xl">⟠</div>
          <p class="text-base font-semibold text-[var(--text-strong)]">Senha atualizada.</p>
          <a href="/login" class="text-sm text-[var(--accent)] hover:underline">
            Acessar NØX
          </a>
        </div>
      </Card>

      <footer class="mt-8 text-center">
        <a href="/login" class="text-sm text-[var(--text-dim)] hover:text-white transition-colors">
          ← Voltar para login
        </a>
      </footer>
    </div>
  </main>
</Layout>

<script>
  const productionApiUrl = 'https://api.noxai.chat';
  const isLocalhost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
  const configuredApiUrl = String((import.meta as any).env?.PUBLIC_API_URL || '').trim().replace(/\/$/, '');
  const configuredApiIsLocal = /^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?/i.test(configuredApiUrl);
  const apiUrl = configuredApiUrl && (isLocalhost || !configuredApiIsLocal)
    ? configuredApiUrl
    : (isLocalhost ? 'http://localhost:3001' : productionApiUrl);

  const resetForm = document.getElementById('reset-form') as HTMLFormElement;
  const resetSuccess = document.getElementById('reset-success') as HTMLDivElement;
  const submitButton = document.getElementById('reset-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('reset-status') as HTMLParagraphElement;

  function setStatus(message: string, isError = false) {
    statusEl.textContent = message;
    statusEl.style.color = isError ? '#ff6b6b' : 'var(--text-soft)';
  }

  resetForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    const formData = new FormData(resetForm);
    const newPassword = String(formData.get('newPassword') || '');
    const confirmPassword = String(formData.get('confirmPassword') || '');

    if (!token) {
      setStatus('Token ausente. Solicite um novo link de recuperação.', true);
      return;
    }

    if (newPassword.length < 8) {
      setStatus('A senha precisa ter pelo menos 8 caracteres.', true);
      return;
    }

    if (newPassword !== confirmPassword) {
      setStatus('As senhas não conferem.', true);
      return;
    }

    submitButton.disabled = true;
    submitButton.innerText = 'Atualizando...';
    setStatus('Validando credencial...');

    try {
      const response = await fetch(`${apiUrl}/api/auth/password-reset/complete`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, newPassword }),
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        setStatus(result.error || 'Não foi possível redefinir a senha.', true);
        return;
      }

      resetForm.classList.add('hidden');
      resetSuccess.classList.remove('hidden');
      resetSuccess.classList.add('flex');
    } catch {
      setStatus('Erro de conexão. Verifique sua internet e tente novamente.', true);
    } finally {
      submitButton.disabled = false;
      submitButton.innerText = 'Atualizar senha';
    }
  });
</script>

<style>
  .scene-shell {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .content-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
  }
</style>
